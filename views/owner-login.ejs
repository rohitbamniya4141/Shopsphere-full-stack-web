<%- include('./partials/header') %>

    <section class="min-h-[85vh] flex items-center">
        <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20 w-full">
            <div class="flex justify-center">

                <!-- Login Card -->
                <div class="w-full max-w-md animate-fade-in-up">
                    <div class="text-center mb-8">
                        <div class="w-16 h-16 rounded-2xl bg-dark-900 flex items-center justify-center mx-auto mb-5">
                            <i class="ri-admin-line text-2xl text-brand-400"></i>
                        </div>
                        <h1 class="text-2xl font-serif font-bold text-dark-900">Admin Access</h1>
                        <p class="text-dark-400 text-sm mt-2">Sign in to manage your store</p>
                    </div>

                    <div class="bg-white rounded-2xl shadow-xl shadow-black/5 border border-gray-100 p-8">
                        <form autocomplete="off" action="/owners/login" method="post" class="space-y-5">
                            <div>
                                <label class="text-xs font-medium text-dark-500 uppercase tracking-wider mb-1.5 block">Admin Email</label>
                                <input class="input-styled w-full px-4 py-3 rounded-xl bg-gray-50 text-dark-900 placeholder-dark-300 text-sm"
                                    type="email" placeholder="admin@shopsphere.com" name="email">
                            </div>
                            <div>
                                <label class="text-xs font-medium text-dark-500 uppercase tracking-wider mb-1.5 block">Password</label>
                                <input class="input-styled w-full px-4 py-3 rounded-xl bg-gray-50 text-dark-900 placeholder-dark-300 text-sm"
                                    type="password" placeholder="••••••••" name="password">
                            </div>
                            <button type="submit" class="w-full btn-dark text-white font-semibold py-3.5 rounded-xl text-sm tracking-wide flex items-center justify-center gap-2">
                                <i class="ri-lock-line"></i>
                                Sign In as Admin
                            </button>
                        </form>
                    </div>

                    <p class="text-center text-dark-400 text-xs mt-6">
                        <a href="/" class="text-brand-600 hover:text-brand-700 font-medium">← Back to main site</a>
                    </p>
                </div>

            </div>
        </div>
    </section>

<%- include('./partials/footer') %>