<%- include('./partials/header') %>

    <!-- Flash Error -->
    <% if(error.length > 0){ %>
        <div class="flash-message fixed top-20 left-1/2 -translate-x-1/2 z-50 px-6 py-3.5 rounded-2xl bg-red-500/90 backdrop-blur-xl shadow-2xl shadow-red-500/25 border border-red-400/30">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0">
                    <i class="ri-error-warning-line text-white text-base"></i>
                </div>
                <span class="text-white text-sm font-medium tracking-wide"><%= error %></span>
                <button onclick="this.closest('.flash-message').remove()" class="ml-2 text-white/70 hover:text-white transition-colors">
                    <i class="ri-close-line text-lg"></i>
                </button>
            </div>
        </div>
    <% } %>

    <!-- Hero Section -->
    <section class="relative min-h-[92vh] flex items-center overflow-hidden">
        <!-- Layered Background -->
        <div class="absolute inset-0 bg-gradient-to-br from-gray-950 via-gray-900 to-gray-800"></div>
        <div class="absolute inset-0" style="background-image: radial-gradient(ellipse 60% 50% at 15% 50%, rgba(212, 136, 46, 0.15), transparent), radial-gradient(ellipse 40% 40% at 85% 20%, rgba(212, 136, 46, 0.1), transparent), radial-gradient(ellipse 30% 30% at 50% 80%, rgba(168, 120, 60, 0.08), transparent);"></div>
        <!-- Subtle grid overlay -->
        <div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 60px 60px;"></div>
        <!-- Top gradient fade -->
        <div class="absolute top-0 left-0 right-0 h-32 bg-gradient-to-b from-gray-950/50 to-transparent"></div>
        <!-- Bottom gradient fade -->
        <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-gray-950/40 to-transparent"></div>

        <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 lg:px-20 w-full py-16 lg:py-0">
            <div class="flex flex-col lg:flex-row items-center gap-16 lg:gap-24">

                <!-- Left: Hero Content + Register -->
                <div class="w-full lg:w-1/2 animate-fade-in-up">
                    <!-- Badge -->
                    <div class="inline-flex items-center gap-2.5 px-5 py-2.5 rounded-full bg-gradient-to-r from-brand-500/10 to-brand-400/5 border border-brand-500/20 mb-10 backdrop-blur-sm">
                        <span class="relative flex h-2.5 w-2.5">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-brand-400"></span>
                        </span>
                        <span class="text-brand-400 text-xs font-semibold uppercase tracking-[0.15em]">Premium Collection 2026</span>
                    </div>

                    <h1 class="text-4xl md:text-5xl lg:text-[3.5rem] xl:text-6xl font-serif font-bold text-white leading-[1.1] mb-7">
                        Discover Your <br>
                        <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-400 via-amber-300 to-brand-300">Perfect Bag</span>
                    </h1>
                    <p class="text-gray-400 text-lg md:text-xl leading-relaxed mb-12 max-w-lg">
                        Handcrafted luxury bags that define your style. From everyday essentials to statement pieces that turn heads.
                    </p>

                    <!-- Register Form — Glassmorphism Card -->
                    <div class="relative group">
                        <!-- Glow behind card -->
                        <div class="absolute -inset-1 bg-gradient-to-r from-brand-500/20 via-transparent to-brand-400/20 rounded-3xl blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                        <div class="relative bg-white/[0.06] backdrop-blur-2xl border border-white/[0.08] rounded-2xl p-8 md:p-9 shadow-2xl shadow-black/20">
                            <!-- Highlight line at top -->
                            <div class="absolute top-0 left-8 right-8 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>

                            <h3 class="text-white text-xl font-semibold mb-1.5 tracking-tight">Create your account</h3>
                            <p class="text-gray-500 text-sm mb-7">Join ShopSphere to start shopping</p>

                            <form autocomplete="off" action="/users/register" method="post" class="space-y-4">
                                <div class="relative">
                                    <div class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500">
                                        <i class="ri-user-3-line text-base"></i>
                                    </div>
                                    <input
                                        class="w-full pl-11 pr-4 py-3.5 rounded-xl bg-white/[0.07] border border-white/[0.08] text-white placeholder-gray-500 focus:border-brand-500/60 focus:bg-white/[0.1] focus:ring-2 focus:ring-brand-500/15 outline-none transition-all duration-300 text-sm"
                                        type="text" placeholder="Full Name" name="fullname">
                                </div>
                                <div class="relative">
                                    <div class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500">
                                        <i class="ri-mail-line text-base"></i>
                                    </div>
                                    <input
                                        class="w-full pl-11 pr-4 py-3.5 rounded-xl bg-white/[0.07] border border-white/[0.08] text-white placeholder-gray-500 focus:border-brand-500/60 focus:bg-white/[0.1] focus:ring-2 focus:ring-brand-500/15 outline-none transition-all duration-300 text-sm"
                                        type="email" placeholder="Email Address" name="email">
                                </div>
                                <div class="relative">
                                    <div class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500">
                                        <i class="ri-lock-2-line text-base"></i>
                                    </div>
                                    <input
                                        class="w-full pl-11 pr-4 py-3.5 rounded-xl bg-white/[0.07] border border-white/[0.08] text-white placeholder-gray-500 focus:border-brand-500/60 focus:bg-white/[0.1] focus:ring-2 focus:ring-brand-500/15 outline-none transition-all duration-300 text-sm"
                                        type="password" placeholder="Password" name="password">
                                </div>
                                <button type="submit" class="w-full bg-gradient-to-r from-brand-500 to-amber-500 hover:from-brand-600 hover:to-amber-600 text-white font-semibold py-3.5 rounded-xl text-sm tracking-wide transition-all duration-300 shadow-lg shadow-brand-500/25 hover:shadow-xl hover:shadow-brand-500/30 hover:-translate-y-0.5 active:translate-y-0 flex items-center justify-center gap-2">
                                    Create Account
                                    <i class="ri-arrow-right-line text-base transition-transform group-hover:translate-x-0.5"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Right: Stats + Login Form -->
                <div class="w-full lg:w-1/2 animate-fade-in-up stagger-2">
                    <!-- Stats Row -->
                    <div class="flex gap-6 sm:gap-10 mb-14">
                        <div class="stagger-1 animate-fade-in-up">
                            <h3 class="text-3xl md:text-4xl font-bold text-white tracking-tight">500+</h3>
                            <p class="text-gray-500 text-sm mt-1.5 font-medium">Premium Bags</p>
                        </div>
                        <div class="w-px bg-white/10 self-stretch"></div>
                        <div class="stagger-2 animate-fade-in-up">
                            <h3 class="text-3xl md:text-4xl font-bold text-white tracking-tight">50+</h3>
                            <p class="text-gray-500 text-sm mt-1.5 font-medium">Brands</p>
                        </div>
                        <div class="w-px bg-white/10 self-stretch"></div>
                        <div class="stagger-3 animate-fade-in-up">
                            <h3 class="text-3xl md:text-4xl font-bold text-white tracking-tight">10K+</h3>
                            <p class="text-gray-500 text-sm mt-1.5 font-medium">Happy Customers</p>
                        </div>
                    </div>

                    <!-- Login Form — White Card -->
                    <div class="bg-white rounded-2xl shadow-2xl shadow-black/8 p-8 md:p-9 border border-gray-100/80 relative overflow-hidden">
                        <!-- Decorative corner accent -->
                        <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-bl from-brand-50 to-transparent rounded-bl-[4rem]"></div>

                        <div class="relative">
                            <!-- Header -->
                            <div class="flex items-center gap-4 mb-8">
                                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-brand-50 to-amber-50 flex items-center justify-center shadow-sm">
                                    <i class="ri-login-box-line text-brand-600 text-xl"></i>
                                </div>
                                <div>
                                    <h3 class="text-xl font-semibold text-gray-900 tracking-tight">Welcome back</h3>
                                    <p class="text-gray-400 text-sm">Login to your account</p>
                                </div>
                            </div>

                            <form autocomplete="off" action="/users/login" method="post" class="space-y-5">
                                <div>
                                    <label class="text-xs font-semibold text-gray-500 uppercase tracking-[0.1em] mb-2 block">Email</label>
                                    <div class="relative">
                                        <div class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">
                                            <i class="ri-mail-line text-base"></i>
                                        </div>
                                        <input
                                            class="w-full pl-11 pr-4 py-3.5 rounded-xl bg-gray-50/80 border border-gray-200 text-gray-900 placeholder-gray-400 focus:border-brand-500 focus:ring-4 focus:ring-brand-500/10 focus:bg-white outline-none transition-all duration-300 text-sm"
                                            type="email" placeholder="you@example.com" name="email">
                                    </div>
                                </div>
                                <div>
                                    <label class="text-xs font-semibold text-gray-500 uppercase tracking-[0.1em] mb-2 block">Password</label>
                                    <div class="relative">
                                        <div class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">
                                            <i class="ri-lock-2-line text-base"></i>
                                        </div>
                                        <input
                                            class="w-full pl-11 pr-4 py-3.5 rounded-xl bg-gray-50/80 border border-gray-200 text-gray-900 placeholder-gray-400 focus:border-brand-500 focus:ring-4 focus:ring-brand-500/10 focus:bg-white outline-none transition-all duration-300 text-sm"
                                            type="password" placeholder="••••••••" name="password">
                                    </div>
                                </div>
                                <button type="submit" class="w-full bg-gradient-to-r from-gray-900 to-gray-800 hover:from-gray-800 hover:to-gray-700 text-white font-semibold py-3.5 rounded-xl text-sm tracking-wide transition-all duration-300 shadow-lg shadow-gray-900/20 hover:shadow-xl hover:shadow-gray-900/25 hover:-translate-y-0.5 active:translate-y-0 flex items-center justify-center gap-2">
                                    Login to Shop
                                    <i class="ri-arrow-right-line text-base"></i>
                                </button>
                            </form>

                            <!-- Divider -->
                            <div class="mt-8 pt-7 border-t border-gray-100 text-center">
                                <p class="text-gray-400 text-sm">
                                    <span class="inline-flex items-center gap-2">
                                        <span class="w-8 h-px bg-gray-200"></span>
                                        New here? Create an account on the left
                                        <span class="text-brand-500"><i class="ri-arrow-left-line"></i></span>
                                        <span class="w-8 h-px bg-gray-200"></span>
                                    </span>
                                </p>
                                <a href="/owners/login" class="inline-flex items-center gap-1.5 mt-4 text-xs font-semibold text-brand-600 hover:text-brand-700 transition-colors duration-200 tracking-wide uppercase">
                                    <i class="ri-shield-keyhole-line text-sm"></i>
                                    Continue as Admin
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Strip -->
    <section class="bg-white border-y border-gray-100 relative overflow-hidden">
        <!-- Subtle background accent -->
        <div class="absolute inset-0 bg-gradient-to-r from-brand-50/30 via-transparent to-brand-50/30"></div>

        <div class="relative max-w-7xl mx-auto px-6 md:px-12 lg:px-20 py-10">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-6">
                <!-- Free Shipping -->
                <div class="flex items-center gap-4 group">
                    <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-brand-50 to-amber-50 flex items-center justify-center flex-shrink-0 shadow-sm group-hover:shadow-md group-hover:scale-105 transition-all duration-300">
                        <i class="ri-truck-line text-brand-600 text-lg"></i>
                    </div>
                    <div>
                        <h4 class="text-sm font-semibold text-gray-900">Free Shipping</h4>
                        <p class="text-xs text-gray-400 mt-0.5">On orders above ₹999</p>
                    </div>
                </div>
                <!-- Genuine Products -->
                <div class="flex items-center gap-4 group">
                    <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-brand-50 to-amber-50 flex items-center justify-center flex-shrink-0 shadow-sm group-hover:shadow-md group-hover:scale-105 transition-all duration-300">
                        <i class="ri-shield-check-line text-brand-600 text-lg"></i>
                    </div>
                    <div>
                        <h4 class="text-sm font-semibold text-gray-900">Genuine Products</h4>
                        <p class="text-xs text-gray-400 mt-0.5">100% authentic</p>
                    </div>
                </div>
                <!-- Easy Returns -->
                <div class="flex items-center gap-4 group">
                    <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-brand-50 to-amber-50 flex items-center justify-center flex-shrink-0 shadow-sm group-hover:shadow-md group-hover:scale-105 transition-all duration-300">
                        <i class="ri-refresh-line text-brand-600 text-lg"></i>
                    </div>
                    <div>
                        <h4 class="text-sm font-semibold text-gray-900">Easy Returns</h4>
                        <p class="text-xs text-gray-400 mt-0.5">7-day return policy</p>
                    </div>
                </div>
                <!-- Secure Payment -->
                <div class="flex items-center gap-4 group">
                    <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-brand-50 to-amber-50 flex items-center justify-center flex-shrink-0 shadow-sm group-hover:shadow-md group-hover:scale-105 transition-all duration-300">
                        <i class="ri-secure-payment-line text-brand-600 text-lg"></i>
                    </div>
                    <div>
                        <h4 class="text-sm font-semibold text-gray-900">Secure Payment</h4>
                        <p class="text-xs text-gray-400 mt-0.5">SSL encrypted</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

<%- include('./partials/footer') %>