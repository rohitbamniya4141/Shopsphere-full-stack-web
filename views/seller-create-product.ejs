<%- include('./partials/seller-header') %>

    <!-- Flash Success -->
    <% if(typeof success !== 'undefined' && success.length > 0){ %>
        <div class="flash-message fixed top-20 left-1/2 -translate-x-1/2 z-50 px-8 py-4 rounded-2xl bg-emerald-500/95 backdrop-blur-md shadow-2xl shadow-emerald-500/25">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0">
                    <i class="ri-check-line text-white text-lg"></i>
                </div>
                <span class="text-white text-sm font-semibold tracking-wide"><%= success %></span>
            </div>
        </div>
    <% } %>

    <div class="max-w-5xl mx-auto px-5 sm:px-8 lg:px-12 py-10 sm:py-14 animate-fade-in-up">

        <!-- Page Header -->
        <div class="mb-8">
            <div class="flex items-center gap-2.5 mb-3">
                <div class="w-1.5 h-6 rounded-full bg-gradient-to-b from-brand-400 to-brand-600"></div>
                <p class="text-brand-600 text-xs font-bold uppercase tracking-[0.15em]">Seller Panel</p>
            </div>
            <h1 class="text-2xl sm:text-3xl font-serif font-bold text-dark-900 tracking-tight leading-tight">Create New Product</h1>
            <p class="text-dark-400 text-sm mt-1.5 leading-relaxed">Add a new item to your store catalog</p>
        </div>

        <!-- Form Card -->
        <div class="bg-white rounded-2xl shadow-lg shadow-black/[0.04] border border-gray-100/80 p-7 sm:p-10">
            <form autocomplete="off" action="/sellers/products/create" method="post" class="space-y-6">

                <!-- Product Name -->
                <div>
                    <label class="text-[11px] font-semibold text-dark-400 uppercase tracking-[0.12em] mb-2 block">Product Name</label>
                    <input class="input-styled w-full px-4 py-3.5 rounded-xl bg-gray-50/70 text-dark-900 placeholder-dark-300 text-sm font-medium"
                        type="text" placeholder="e.g. Urban Edge Backpack" name="name" required>
                </div>

                <!-- Price + Discount -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                    <div>
                        <label class="text-[11px] font-semibold text-dark-400 uppercase tracking-[0.12em] mb-2 block">Price (₹)</label>
                        <input class="input-styled w-full px-4 py-3.5 rounded-xl bg-gray-50/70 text-dark-900 placeholder-dark-300 text-sm font-medium"
                            type="number" placeholder="e.g. 2999" name="price" required>
                    </div>
                    <div>
                        <label class="text-[11px] font-semibold text-dark-400 uppercase tracking-[0.12em] mb-2 block">Discount (₹)</label>
                        <input class="input-styled w-full px-4 py-3.5 rounded-xl bg-gray-50/70 text-dark-900 placeholder-dark-300 text-sm font-medium"
                            type="number" placeholder="e.g. 500" name="discount" value="0">
                    </div>
                </div>

                <!-- Category + Stock -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                    <div>
                        <label class="text-[11px] font-semibold text-dark-400 uppercase tracking-[0.12em] mb-2 block">Category</label>
                        <select name="category" class="input-styled w-full px-4 py-3.5 rounded-xl bg-gray-50/70 text-dark-900 text-sm font-medium cursor-pointer">
                            <option value="Backpacks">Backpacks</option>
                            <option value="Laptop Bags">Laptop Bags</option>
                            <option value="Travel Bags">Travel Bags</option>
                            <option value="Office Bags">Office Bags</option>
                            <option value="Tote & Sling Bags">Tote & Sling Bags</option>
                            <option value="General">General</option>
                        </select>
                    </div>
                    <div>
                        <label class="text-[11px] font-semibold text-dark-400 uppercase tracking-[0.12em] mb-2 block">Stock</label>
                        <input class="input-styled w-full px-4 py-3.5 rounded-xl bg-gray-50/70 text-dark-900 placeholder-dark-300 text-sm font-medium"
                            type="number" placeholder="e.g. 50" name="stock" value="0">
                    </div>
                </div>

                <!-- Image URL -->
                <div>
                    <label class="text-[11px] font-semibold text-dark-400 uppercase tracking-[0.12em] mb-2 block">Image URL Path</label>
                    <input class="input-styled w-full px-4 py-3.5 rounded-xl bg-gray-50/70 text-dark-900 placeholder-dark-300 text-sm font-medium"
                        type="text" placeholder="/images/products/my-product.jpg" name="image">
                    <p class="text-[10px] text-dark-300 mt-1.5">Enter the image path relative to /public folder</p>
                </div>

                <!-- Description -->
                <div>
                    <label class="text-[11px] font-semibold text-dark-400 uppercase tracking-[0.12em] mb-2 block">Description</label>
                    <textarea class="input-styled w-full px-4 py-3.5 rounded-xl bg-gray-50/70 text-dark-900 placeholder-dark-300 text-sm font-medium resize-none"
                        rows="4" placeholder="Describe your product in detail..." name="description"></textarea>
                </div>

                <!-- Colors -->
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
                    <div>
                        <label class="text-[11px] font-semibold text-dark-400 uppercase tracking-[0.12em] mb-2 block">Background Color</label>
                        <input class="input-styled w-full px-4 py-3.5 rounded-xl bg-gray-50/70 text-dark-900 placeholder-dark-300 text-sm font-medium"
                            type="text" name="bgcolor" value="#F3F4F6" placeholder="#F3F4F6">
                    </div>
                    <div>
                        <label class="text-[11px] font-semibold text-dark-400 uppercase tracking-[0.12em] mb-2 block">Panel Color</label>
                        <input class="input-styled w-full px-4 py-3.5 rounded-xl bg-gray-50/70 text-dark-900 placeholder-dark-300 text-sm font-medium"
                            type="text" name="panelcolor" value="#FFFFFF" placeholder="#FFFFFF">
                    </div>
                    <div>
                        <label class="text-[11px] font-semibold text-dark-400 uppercase tracking-[0.12em] mb-2 block">Text Color</label>
                        <input class="input-styled w-full px-4 py-3.5 rounded-xl bg-gray-50/70 text-dark-900 placeholder-dark-300 text-sm font-medium"
                            type="text" name="textcolor" value="#111827" placeholder="#111827">
                    </div>
                </div>

                <!-- Submit -->
                <div class="pt-3">
                    <button type="submit" class="w-full sm:w-auto btn-primary text-white font-bold py-4 px-10 rounded-xl text-sm tracking-wide flex items-center justify-center gap-2.5">
                        <i class="ri-add-circle-line text-lg"></i>
                        Create Product
                    </button>
                </div>

            </form>
        </div>

    </div>

<%- include('./partials/footer') %>
