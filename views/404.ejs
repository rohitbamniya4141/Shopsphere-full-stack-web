<%- include('./partials/header') %>

    <div class="min-h-[70vh] flex flex-col items-center justify-center px-6 py-20 animate-fade-in-up">

        <div class="w-32 h-32 rounded-3xl bg-gradient-to-br from-brand-50 to-brand-100 flex items-center justify-center mb-8 shadow-sm">
            <i class="ri-error-warning-line text-6xl text-brand-400"></i>
        </div>

        <h1 class="text-5xl sm:text-6xl font-serif font-bold text-dark-900 tracking-tight mb-4">404</h1>

        <h2 class="text-xl sm:text-2xl font-semibold text-dark-700 mb-3">Page Not Found</h2>

        <p class="text-dark-400 text-sm text-center max-w-md leading-relaxed mb-10">
            The page you're looking for doesn't exist or has been moved. Let's get you back on track.
        </p>

        <div class="flex flex-col sm:flex-row gap-3">
            <a href="/shop" class="btn-primary text-white font-semibold px-8 py-3.5 rounded-2xl text-sm tracking-wide inline-flex items-center justify-center gap-2.5">
                <i class="ri-shopping-bag-line"></i>
                Browse Shop
            </a>
            <a href="/" class="px-8 py-3.5 rounded-2xl border border-gray-200 text-dark-500 text-sm font-semibold hover:bg-gray-50 hover:border-gray-300 hover:text-dark-700 transition-all duration-200 inline-flex items-center justify-center gap-2">
                <i class="ri-home-line"></i>
                Go Home
            </a>
        </div>

    </div>

<%- include('./partials/footer') %>
