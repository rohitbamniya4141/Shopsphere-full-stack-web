    <!-- Floating Toggle Button -->
    <button id="ai-chat-toggle" onclick="toggleAiChat()" title="ShopSphere AI Assistant">
        <span class="ai-pulse"></span>
        <i class="ri-sparkling-2-fill"></i>
    </button>

    <!-- Chat Popup -->
    <div id="ai-chat-popup" class="ai-hidden">

        <!-- Header -->
        <div id="ai-chat-header">
            <div class="ai-avatar">
                <i class="ri-sparkling-2-fill"></i>
            </div>
            <div class="ai-info">
                <div class="ai-title">ShopSphere AI</div>
                <div class="ai-subtitle">Your personal shopping assistant</div>
            </div>
            <button id="ai-chat-close" onclick="toggleAiChat()">
                <i class="ri-close-line"></i>
            </button>
        </div>

        <!-- Messages -->
        <div id="ai-chat-messages">
            <div class="ai-msg ai-bot">
                Hey there! 👋 I'm <strong>ShopSphere AI</strong>. I can help you find the perfect bag, compare products, or recommend gifts. Just ask me anything!
            </div>
        </div>

        <!-- Input -->
        <div id="ai-chat-input-area">
            <input type="text" id="ai-chat-input" placeholder="Ask about bags, budgets, gifts..."
                   onkeydown="if(event.key==='Enter') sendAiMessage();" autocomplete="off">
            <button id="ai-chat-send" onclick="sendAiMessage()">
                <i class="ri-send-plane-2-fill"></i>
            </button>
        </div>

    </div>

    <script>
    (function() {
        // ===== State =====
        let chatOpen = false;
        let isLoading = false;
        const history = []; // conversation memory (session only)

        // ===== DOM References =====
        const popup = document.getElementById('ai-chat-popup');
        const messagesDiv = document.getElementById('ai-chat-messages');
        const inputEl = document.getElementById('ai-chat-input');
        const sendBtn = document.getElementById('ai-chat-send');
        const toggleBtn = document.getElementById('ai-chat-toggle');

        // ===== Toggle Chat =====
        window.toggleAiChat = function() {
            chatOpen = !chatOpen;
            if (chatOpen) {
                popup.classList.remove('ai-hidden');
                popup.classList.add('ai-visible');
                toggleBtn.style.transform = 'scale(0)';
                setTimeout(function() { inputEl.focus(); }, 350);
            } else {
                popup.classList.remove('ai-visible');
                popup.classList.add('ai-hidden');
                toggleBtn.style.transform = 'scale(1)';
            }
        };

        // ===== Add Message to UI =====
        function addMessage(text, sender, products) {
            const msgDiv = document.createElement('div');
            msgDiv.className = 'ai-msg ' + (sender === 'user' ? 'ai-user' : 'ai-bot');

            // Format AI text: bold, line breaks
            if (sender === 'bot') {
                let formatted = text
                    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
                    .replace(/\n/g, '<br>');
                msgDiv.innerHTML = formatted;

                // Add product cards if provided
                if (products && products.length > 0) {
                    const cardsDiv = document.createElement('div');
                    cardsDiv.className = 'ai-product-cards';
                    products.forEach(function(p) {
                        const effectivePrice = p.price - (p.discount || 0);
                        const card = document.createElement('a');
                        card.href = '/product/' + p._id;
                        card.className = 'ai-product-card';

                        let priceHtml = '<span class="ai-pc-price">₹' + effectivePrice.toLocaleString('en-IN') + '</span>';
                        if (p.discount > 0) {
                            priceHtml += ' <span class="ai-pc-original">₹' + p.price.toLocaleString('en-IN') + '</span>';
                            priceHtml += ' <span class="ai-pc-discount">-₹' + p.discount.toLocaleString('en-IN') + '</span>';
                        }

                        let ratingHtml = '';
                        if (p.avgRating > 0) {
                            ratingHtml = '<span class="ai-pc-rating">★ ' + p.avgRating + '/5</span>';
                        }

                        let stockHtml = '';
                        if (p.stock <= 5) {
                            stockHtml = '<span class="ai-pc-stock low">Only ' + p.stock + ' left!</span>';
                        } else {
                            stockHtml = '<span class="ai-pc-stock">In Stock</span>';
                        }

                        card.innerHTML =
                            '<div class="ai-pc-top">' +
                                '<span class="ai-pc-name">' + p.name + '</span>' +
                                '<span class="ai-pc-category">' + p.category + '</span>' +
                            '</div>' +
                            '<div class="ai-pc-bottom">' +
                                priceHtml + stockHtml + ratingHtml +
                            '</div>';

                        cardsDiv.appendChild(card);
                    });
                    msgDiv.appendChild(cardsDiv);
                }
            } else {
                msgDiv.textContent = text;
            }

            messagesDiv.appendChild(msgDiv);
            messagesDiv.scrollTop = messagesDiv.scrollHeight;
        }

        // ===== Typing Indicator =====
        function showTyping() {
            const typingDiv = document.createElement('div');
            typingDiv.className = 'ai-typing';
            typingDiv.id = 'ai-typing-indicator';
            typingDiv.innerHTML = '<div class="ai-typing-dot"></div><div class="ai-typing-dot"></div><div class="ai-typing-dot"></div>';
            messagesDiv.appendChild(typingDiv);
            messagesDiv.scrollTop = messagesDiv.scrollHeight;
        }

        function hideTyping() {
            const el = document.getElementById('ai-typing-indicator');
            if (el) el.remove();
        }

        // ===== Send Message =====
        window.sendAiMessage = async function() {
            if (isLoading) return;

            const message = inputEl.value.trim();
            if (!message) return;

            // Add user message
            addMessage(message, 'user');
            history.push({ role: 'user', content: message });
            inputEl.value = '';

            // Loading state
            isLoading = true;
            sendBtn.disabled = true;
            showTyping();

            try {
                const res = await fetch('/ai/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        message: message,
                        history: history.slice(-6) // last 6 messages for context
                    })
                });

                const data = await res.json();

                hideTyping();
                addMessage(data.reply, 'bot', data.products);
                history.push({ role: 'assistant', content: data.reply });

            } catch (err) {
                hideTyping();
                addMessage("Couldn't reach the server. Please check your connection and try again. 🔌", 'bot');
            }

            isLoading = false;
            sendBtn.disabled = false;
            inputEl.focus();
        };
    })();
    </script>
    <% } %>

</body>

