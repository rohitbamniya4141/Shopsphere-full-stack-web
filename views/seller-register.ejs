<%- include('./partials/seller-header') %>

    <!-- Flash Error -->
    <% if(typeof error !== 'undefined' && error.length > 0){ %>
        <div class="flash-message fixed top-20 left-1/2 -translate-x-1/2 z-50 px-6 py-3.5 rounded-2xl bg-red-500/90 backdrop-blur-xl shadow-2xl shadow-red-500/25 border border-red-400/30">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0">
                    <i class="ri-error-warning-line text-white text-base"></i>
                </div>
                <span class="text-white text-sm font-medium tracking-wide"><%= error %></span>
                <button onclick="this.closest('.flash-message').remove()" class="ml-2 text-white/70 hover:text-white transition-colors">
                    <i class="ri-close-line text-lg"></i>
                </button>
            </div>
        </div>
    <% } %>

    <!-- Flash Success -->
    <% if(typeof success !== 'undefined' && success.length > 0){ %>
        <div class="flash-message fixed top-20 left-1/2 -translate-x-1/2 z-50 px-8 py-4 rounded-2xl bg-emerald-500/95 backdrop-blur-md shadow-2xl shadow-emerald-500/25">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0">
                    <i class="ri-check-line text-white text-lg"></i>
                </div>
                <span class="text-white text-sm font-semibold tracking-wide"><%= success %></span>
            </div>
        </div>
    <% } %>

    <section class="min-h-[85vh] flex items-center justify-center relative overflow-hidden py-12">

        <!-- Subtle background pattern -->
        <div class="absolute inset-0 opacity-[0.015]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23000000&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>

        <div class="max-w-7xl mx-auto px-5 sm:px-6 md:px-12 lg:px-20 w-full relative z-10">
            <div class="flex justify-center">

                <!-- Register Card -->
                <div class="w-full max-w-lg animate-fade-in-up">

                    <!-- Icon & Title -->
                    <div class="text-center mb-8">
                        <div class="relative inline-block mb-6">
                            <div class="w-[72px] h-[72px] rounded-2xl bg-gradient-to-br from-dark-900 to-dark-800 flex items-center justify-center mx-auto shadow-2xl shadow-dark-900/30 rotate-3 hover:rotate-0 transition-transform duration-500">
                                <i class="ri-store-2-line text-3xl text-brand-400"></i>
                            </div>
                            <div class="absolute -bottom-1 -right-1 w-5 h-5 rounded-full bg-brand-400 border-[3px] border-[#fafaf9] flex items-center justify-center">
                                <i class="ri-add-line text-white text-[8px]"></i>
                            </div>
                        </div>
                        <h1 class="text-2xl sm:text-[1.75rem] font-serif font-bold text-dark-900 tracking-tight">Become a Seller</h1>
                        <p class="text-dark-400 text-sm mt-2.5 leading-relaxed">Join ShopSphere marketplace</p>
                    </div>

                    <!-- Form Card -->
                    <div class="bg-white rounded-2xl shadow-2xl shadow-black/[0.06] border border-gray-100/80 p-7 sm:p-8">
                        <form autocomplete="off" action="/sellers/register" method="post" class="space-y-5">

                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                                <div>
                                    <label class="text-[11px] font-semibold text-dark-400 uppercase tracking-[0.12em] mb-2 block">Full Name</label>
                                    <div class="relative">
                                        <div class="absolute left-4 top-1/2 -translate-y-1/2 text-dark-300">
                                            <i class="ri-user-line text-base"></i>
                                        </div>
                                        <input class="input-styled w-full pl-11 pr-4 py-3.5 rounded-xl bg-gray-50/70 text-dark-900 placeholder-dark-300 text-sm font-medium"
                                            type="text" placeholder="John Doe" name="fullname" required>
                                    </div>
                                </div>

                                <div>
                                    <label class="text-[11px] font-semibold text-dark-400 uppercase tracking-[0.12em] mb-2 block">Email</label>
                                    <div class="relative">
                                        <div class="absolute left-4 top-1/2 -translate-y-1/2 text-dark-300">
                                            <i class="ri-mail-line text-base"></i>
                                        </div>
                                        <input class="input-styled w-full pl-11 pr-4 py-3.5 rounded-xl bg-gray-50/70 text-dark-900 placeholder-dark-300 text-sm font-medium"
                                            type="email" placeholder="seller@email.com" name="email" required>
                                    </div>
                                </div>
                            </div>

                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                                <div>
                                    <label class="text-[11px] font-semibold text-dark-400 uppercase tracking-[0.12em] mb-2 block">Phone</label>
                                    <div class="relative">
                                        <div class="absolute left-4 top-1/2 -translate-y-1/2 text-dark-300">
                                            <i class="ri-phone-line text-base"></i>
                                        </div>
                                        <input class="input-styled w-full pl-11 pr-4 py-3.5 rounded-xl bg-gray-50/70 text-dark-900 placeholder-dark-300 text-sm font-medium"
                                            type="tel" placeholder="+91 9876543210" name="phone" required>
                                    </div>
                                </div>

                                <div>
                                    <label class="text-[11px] font-semibold text-dark-400 uppercase tracking-[0.12em] mb-2 block">Shop Name</label>
                                    <div class="relative">
                                        <div class="absolute left-4 top-1/2 -translate-y-1/2 text-dark-300">
                                            <i class="ri-store-2-line text-base"></i>
                                        </div>
                                        <input class="input-styled w-full pl-11 pr-4 py-3.5 rounded-xl bg-gray-50/70 text-dark-900 placeholder-dark-300 text-sm font-medium"
                                            type="text" placeholder="My Bag Store" name="shopName" required>
                                    </div>
                                </div>
                            </div>

                            <div>
                                <label class="text-[11px] font-semibold text-dark-400 uppercase tracking-[0.12em] mb-2 block">Shop Description</label>
                                <textarea name="shopDescription" rows="3" placeholder="Tell us about your store and what you sell..."
                                    class="input-styled w-full px-4 py-3.5 rounded-xl bg-gray-50/70 text-dark-900 placeholder-dark-300 text-sm font-medium resize-none"></textarea>
                            </div>

                            <div>
                                <label class="text-[11px] font-semibold text-dark-400 uppercase tracking-[0.12em] mb-2 block">Password</label>
                                <div class="relative">
                                    <div class="absolute left-4 top-1/2 -translate-y-1/2 text-dark-300">
                                        <i class="ri-lock-2-line text-base"></i>
                                    </div>
                                    <input class="input-styled w-full pl-11 pr-4 py-3.5 rounded-xl bg-gray-50/70 text-dark-900 placeholder-dark-300 text-sm font-medium"
                                        type="password" placeholder="••••••••" name="password" required>
                                </div>
                            </div>

                            <!-- Admin Review Note -->
                            <div class="bg-amber-50 border border-amber-200/60 rounded-xl p-4 flex items-start gap-3">
                                <div class="w-8 h-8 rounded-lg bg-amber-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                                    <i class="ri-information-line text-amber-600 text-base"></i>
                                </div>
                                <div>
                                    <p class="text-xs font-semibold text-amber-800">Account Review</p>
                                    <p class="text-[11px] text-amber-600 mt-0.5 leading-relaxed">Your account will be reviewed by admin before activation. You'll be notified once approved.</p>
                                </div>
                            </div>

                            <div class="pt-1">
                                <button type="submit" class="w-full btn-primary text-white font-bold py-4 rounded-xl text-sm tracking-wide flex items-center justify-center gap-2.5">
                                    <i class="ri-store-2-line text-base"></i>
                                    Register as Seller
                                </button>
                            </div>

                        </form>
                    </div>

                    <!-- Footer -->
                    <div class="text-center mt-7 space-y-3">
                        <p>
                            <a href="/sellers/login" class="inline-flex items-center gap-1.5 text-brand-600 hover:text-brand-700 text-sm font-semibold transition-colors duration-200">
                                <i class="ri-login-box-line text-base"></i>
                                Already a seller? Login
                            </a>
                        </p>
                        <p>
                            <a href="/" class="inline-flex items-center gap-1.5 text-brand-600 hover:text-brand-700 text-sm font-semibold transition-colors duration-200">
                                <i class="ri-arrow-left-s-line text-base"></i>
                                Back to main site
                            </a>
                        </p>
                        <div class="flex items-center justify-center gap-2 text-[11px] text-dark-300 font-medium">
                            <i class="ri-shield-check-line text-emerald-400"></i>
                            Secure seller registration
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

<%- include('./partials/footer') %>
