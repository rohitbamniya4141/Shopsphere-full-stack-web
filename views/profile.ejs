<%- include('./partials/header') %>

    <div class="max-w-4xl mx-auto px-6 md:px-12 py-12">

        <!-- Profile Card -->
        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden animate-fade-in-up">

            <!-- Top Accent Bar -->
            <div class="h-32 bg-gradient-to-r from-brand-500 via-brand-400 to-brand-600 relative overflow-hidden">
                <div class="absolute inset-0 opacity-20">
                    <div class="absolute -top-10 -right-10 w-40 h-40 rounded-full bg-white/10"></div>
                    <div class="absolute -bottom-10 -left-10 w-32 h-32 rounded-full bg-white/10"></div>
                    <div class="absolute top-6 right-20 w-16 h-16 rounded-full bg-white/5"></div>
                </div>
            </div>

            <!-- Avatar & Info Section -->
            <div class="px-8 sm:px-10 pb-10 -mt-14 relative">

                <!-- Avatar -->
                <div class="mb-8">
                    <div class="w-28 h-28 rounded-full bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center text-white text-4xl font-bold ring-4 ring-white shadow-xl shadow-brand-500/20">
                        <%= user.fullname.charAt(0).toUpperCase() %>
                    </div>
                </div>

                <!-- Name & Email -->
                <div class="mb-10">
                    <h1 class="text-3xl md:text-4xl font-serif font-bold text-dark-900 tracking-tight">
                        <%= user.fullname %>
                    </h1>
                    <div class="flex items-center gap-2 mt-3">
                        <i class="ri-mail-line text-dark-300 text-sm"></i>
                        <p class="text-dark-400 text-sm tracking-wide">
                            <%= user.email %>
                        </p>
                    </div>
                </div>

                <!-- Stats Grid -->
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

                    <!-- Cart Items Stat -->
                    <div class="group bg-gradient-to-br from-gray-50 to-white rounded-2xl p-6 border border-gray-100 hover:border-brand-200 hover:shadow-md hover:shadow-brand-100/30 transition-all duration-300">
                        <div class="flex items-center gap-3 mb-4">
                            <div class="w-10 h-10 rounded-xl bg-brand-50 flex items-center justify-center group-hover:bg-brand-100 transition-colors">
                                <i class="ri-shopping-cart-2-line text-brand-500 text-lg"></i>
                            </div>
                            <h3 class="text-xs text-dark-400 uppercase tracking-widest font-semibold">Cart Items</h3>
                        </div>
                        <p class="text-4xl font-bold text-dark-900 tracking-tight tabular-nums">
                            <%= user.cart.length %>
                        </p>
                    </div>

                    <!-- Total Orders Stat -->
                    <div class="group bg-gradient-to-br from-gray-50 to-white rounded-2xl p-6 border border-gray-100 hover:border-emerald-200 hover:shadow-md hover:shadow-emerald-100/30 transition-all duration-300">
                        <div class="flex items-center gap-3 mb-4">
                            <div class="w-10 h-10 rounded-xl bg-emerald-50 flex items-center justify-center group-hover:bg-emerald-100 transition-colors">
                                <i class="ri-box-3-line text-emerald-500 text-lg"></i>
                            </div>
                            <h3 class="text-xs text-dark-400 uppercase tracking-widest font-semibold">Total Orders</h3>
                        </div>
                        <p class="text-4xl font-bold text-dark-900 tracking-tight tabular-nums">
                            <%= user.orders.length %>
                        </p>
                    </div>

                    <!-- Member Since Stat -->
                    <div class="group bg-gradient-to-br from-gray-50 to-white rounded-2xl p-6 border border-gray-100 hover:border-blue-200 hover:shadow-md hover:shadow-blue-100/30 transition-all duration-300">
                        <div class="flex items-center gap-3 mb-4">
                            <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center group-hover:bg-blue-100 transition-colors">
                                <i class="ri-vip-crown-2-line text-blue-500 text-lg"></i>
                            </div>
                            <h3 class="text-xs text-dark-400 uppercase tracking-widest font-semibold">Member Since</h3>
                        </div>
                        <p class="text-lg font-bold text-dark-900 tracking-tight">
                            ShopSphere User
                        </p>
                        <p class="text-xs text-dark-300 mt-1">Premium Member</p>
                    </div>

                </div>
            </div>
        </div>

        <!-- Become a Seller Section -->
        <div class="mt-8 bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden animate-fade-in-up stagger-2">
            <div class="px-8 sm:px-10 py-8">
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center shadow-md shadow-brand-500/20">
                        <i class="ri-store-2-line text-white text-xl"></i>
                    </div>
                    <div>
                        <h2 class="text-xl font-serif font-bold text-dark-900 tracking-tight">Become a Seller</h2>
                        <p class="text-xs text-dark-400">Start selling your products on ShopSphere</p>
                    </div>
                </div>

                <p class="text-dark-500 text-sm leading-relaxed mb-6">
                    Reach thousands of customers through our AI-powered shopping platform. Set up your store in minutes and start growing your business today.
                </p>

                <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3">
                    <a href="/sellers/register"
                       class="btn-primary px-8 py-3.5 rounded-xl text-white text-sm font-semibold tracking-wide flex items-center gap-2.5">
                        <i class="ri-store-2-line text-base"></i>
                        Become a Seller
                    </a>
                    <a href="/sellers/login"
                       class="text-brand-600 hover:text-brand-700 text-sm font-semibold transition-colors flex items-center gap-1.5">
                        <i class="ri-login-box-line text-base"></i>
                        Already a seller? Login
                    </a>
                </div>
            </div>
        </div>

        <!-- Want to Sell CTA Banner -->
        <div class="mt-8 bg-gradient-to-br from-dark-900 to-dark-800 rounded-3xl overflow-hidden animate-fade-in-up stagger-3 relative">
            <div class="absolute inset-0 opacity-10">
                <div class="absolute -top-10 -right-10 w-48 h-48 rounded-full bg-brand-500/30"></div>
                <div class="absolute -bottom-8 -left-8 w-36 h-36 rounded-full bg-brand-400/20"></div>
            </div>
            <div class="px-8 sm:px-10 py-10 relative z-10">
                <h3 class="text-xl sm:text-2xl font-serif font-bold text-white tracking-tight mb-3">Want to sell on ShopSphere?</h3>
                <p class="text-dark-300 text-sm leading-relaxed mb-6 max-w-lg">
                    Start your own online bag store in minutes.
                </p>
                <div class="flex flex-col sm:flex-row gap-3 sm:gap-6 mb-6">
                    <span class="flex items-center gap-2 text-emerald-400 text-sm font-medium">
                        <i class="ri-check-line"></i> AI-powered product discovery
                    </span>
                    <span class="flex items-center gap-2 text-emerald-400 text-sm font-medium">
                        <i class="ri-check-line"></i> Secure payments
                    </span>
                    <span class="flex items-center gap-2 text-emerald-400 text-sm font-medium">
                        <i class="ri-check-line"></i> Seller analytics
                    </span>
                </div>
                <a href="/sellers/register"
                   class="btn-primary inline-flex items-center gap-2.5 px-8 py-3.5 rounded-xl text-white text-sm font-semibold tracking-wide">
                    <i class="ri-store-2-line text-base"></i>
                    Become a Seller
                </a>
            </div>
        </div>

    </div>

<%- include('./partials/footer') %>