<%- include('./partials/header') %>

<div class="max-w-4xl mx-auto px-6 py-10">

    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">

        <div class="flex items-center gap-5 mb-8">

            <div class="w-20 h-20 rounded-full bg-brand-500 flex items-center justify-center text-white text-3xl font-bold">
                <%= user.fullname.charAt(0).toUpperCase() %>
            </div>

            <div>
                <h1 class="text-3xl font-bold text-dark-900">
                    <%= user.fullname %>
                </h1>

                <p class="text-dark-500">
                    <%= user.email %>
                </p>
            </div>

        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">

            <div class="bg-gray-50 rounded-xl p-5">
                <h3 class="text-sm text-dark-400">Cart Items</h3>
                <p class="text-3xl font-bold mt-2">
                    <%= user.cart.length %>
                </p>
            </div>

            <div class="bg-gray-50 rounded-xl p-5">
                <h3 class="text-sm text-dark-400">Total Orders</h3>
                <p class="text-3xl font-bold mt-2">
                    <%= user.orders.length %>
                </p>
            </div>

            <div class="bg-gray-50 rounded-xl p-5">
                <h3 class="text-sm text-dark-400">Member Since</h3>
                <p class="text-lg font-semibold mt-2">
                    ShopSphere User
                </p>
            </div>

        </div>

    </div>

</div>

<%- include('./partials/footer') %>