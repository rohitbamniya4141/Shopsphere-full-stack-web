<%- include('./partials/seller-header') %>

<div class="max-w-7xl mx-auto px-6 py-10">

    <!-- Header -->
    <div class="mb-10">
        <p class="text-brand-500 font-semibold uppercase tracking-widest text-sm">
            Seller Panel
        </p>

        <h1 class="text-4xl font-bold text-gray-800 mt-2">
            Welcome, <%= seller.shopName %> 👋
        </h1>

        <p class="text-gray-500 mt-2">
            Manage your products, orders and store performance from one place.
        </p>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-10">

        <div class="group bg-white rounded-2xl border border-gray-100/80 shadow-sm hover:shadow-lg hover:shadow-blue-500/[0.04] p-5 sm:p-6 transition-all duration-300 hover:-translate-y-0.5">
            <div class="flex items-center justify-between mb-3">
                <p class="text-dark-400 text-xs font-semibold uppercase tracking-wider">Products</p>
                <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                    <i class="ri-shopping-bag-3-line text-blue-500 text-lg"></i>
                </div>
            </div>
            <h2 class="text-3xl font-extrabold text-dark-900 tracking-tight"><%= totalProducts %></h2>
            <p class="text-[11px] text-dark-300 mt-1.5 font-medium">Active items in your store</p>
        </div>

        <div class="group bg-white rounded-2xl border border-gray-100/80 shadow-sm hover:shadow-lg hover:shadow-green-500/[0.04] p-5 sm:p-6 transition-all duration-300 hover:-translate-y-0.5">
            <div class="flex items-center justify-between mb-3">
                <p class="text-dark-400 text-xs font-semibold uppercase tracking-wider">Orders</p>
                <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                    <i class="ri-file-list-3-line text-green-500 text-lg"></i>
                </div>
            </div>
            <h2 class="text-3xl font-extrabold text-dark-900 tracking-tight"><%= totalOrders %></h2>
            <p class="text-[11px] text-dark-300 mt-1.5 font-medium">Total orders received</p>
        </div>

        <div class="group bg-white rounded-2xl border border-gray-100/80 shadow-sm hover:shadow-lg hover:shadow-emerald-500/[0.04] p-5 sm:p-6 transition-all duration-300 hover:-translate-y-0.5">
            <div class="flex items-center justify-between mb-3">
                <p class="text-dark-400 text-xs font-semibold uppercase tracking-wider">Revenue</p>
                <div class="w-10 h-10 rounded-xl bg-emerald-50 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                    <i class="ri-money-rupee-circle-line text-emerald-500 text-lg"></i>
                </div>
            </div>
            <h2 class="text-3xl font-extrabold text-emerald-600 tracking-tight">₹<%= revenue.toLocaleString('en-IN') %></h2>
            <p class="text-[11px] text-dark-300 mt-1.5 font-medium">Total revenue earned</p>
        </div>

        <div class="group bg-white rounded-2xl border border-gray-100/80 shadow-sm hover:shadow-lg hover:shadow-amber-500/[0.04] p-5 sm:p-6 transition-all duration-300 hover:-translate-y-0.5">
            <div class="flex items-center justify-between mb-3">
                <p class="text-dark-400 text-xs font-semibold uppercase tracking-wider">Pending</p>
                <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                    <i class="ri-time-line text-amber-500 text-lg"></i>
                </div>
            </div>
            <h2 class="text-3xl font-extrabold text-dark-900 tracking-tight"><%= pendingOrders %></h2>
            <p class="text-[11px] text-dark-300 mt-1.5 font-medium">Orders awaiting action</p>
        </div>

    </div>

    <!-- Top Selling Products -->
    <% if(topProducts && topProducts.length > 0){ %>
        <div class="mb-10">
            <div class="flex items-center justify-between mb-6">
                <div>
                    <h2 class="text-xl font-bold text-dark-900 tracking-tight">Top Selling Products</h2>
                    <p class="text-dark-400 text-sm mt-0.5">Best performing items by sales volume</p>
                </div>
                <a href="/sellers/products" class="text-xs font-semibold text-brand-600 hover:text-brand-700 transition-colors flex items-center gap-1">
                    View All <i class="ri-arrow-right-s-line"></i>
                </a>
            </div>
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                <% topProducts.forEach(function(item, idx){ %>
                    <div class="flex items-center gap-4 px-6 py-4 <%= idx < topProducts.length - 1 ? 'border-b border-gray-50' : '' %> hover:bg-gray-50/50 transition-colors">
                        <span class="w-8 h-8 rounded-lg flex items-center justify-center text-xs font-bold flex-shrink-0
                            <%= idx === 0 ? 'bg-amber-100 text-amber-700' : idx === 1 ? 'bg-gray-100 text-gray-600' : idx === 2 ? 'bg-orange-100 text-orange-600' : 'bg-gray-50 text-gray-400' %>
                        ">#<%= idx + 1 %></span>
                        <% if(item.product && item.product.image){ %>
                            <div class="w-12 h-12 rounded-xl overflow-hidden flex-shrink-0" style="background-color: <%= item.product.bgcolor || '#f5f5f5' %>">
                                <img src="<%= item.product.image %>" class="w-full h-full object-contain" alt="<%= item.product.name %>">
                            </div>
                        <% } %>
                        <div class="min-w-0 flex-1">
                            <p class="text-sm font-semibold text-dark-800 truncate"><%= item.product ? item.product.name : 'Deleted Product' %></p>
                            <p class="text-xs text-dark-400">₹<%= item.price %></p>
                        </div>
                        <div class="text-right flex-shrink-0">
                            <p class="text-sm font-bold text-dark-900"><%= item.totalSold %> sold</p>
                            <p class="text-xs text-emerald-600 font-medium">₹<%= item.totalRevenue.toLocaleString('en-IN') %></p>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
    <% } %>

    <!-- Recent Orders -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-10">

        <!-- Latest Orders -->
        <div>
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-bold text-dark-900">Recent Orders</h2>
                <a href="/sellers/orders" class="text-xs font-semibold text-brand-600 hover:text-brand-700 transition-colors flex items-center gap-1">
                    View All <i class="ri-arrow-right-s-line"></i>
                </a>
            </div>
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                <% if(recentOrders && recentOrders.length > 0){ %>
                    <% recentOrders.forEach(function(order, idx){ %>
                        <div class="flex items-center gap-4 px-5 py-4 <%= idx < recentOrders.length - 1 ? 'border-b border-gray-50' : '' %> hover:bg-gray-50/50 transition-colors">
                            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-100 to-brand-200 flex items-center justify-center flex-shrink-0">
                                <i class="ri-box-3-line text-brand-600"></i>
                            </div>
                            <div class="min-w-0 flex-1">
                                <p class="text-sm font-semibold text-dark-800 truncate"><%= order.user ? order.user.fullname : 'Unknown' %></p>
                                <%
                                const isNewFormat = order.purchasedItems && order.purchasedItems.length > 0;
                                const itemsSource = isNewFormat ? order.purchasedItems : order.products;
                                %>
                                <p class="text-xs text-dark-400"><%= itemsSource.length %> item(s) · <%= new Date(order.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) %></p>
                            </div>
                            <div class="text-right flex-shrink-0">
                                <p class="text-sm font-bold text-dark-900">₹<%= order.totalAmount %></p>
                                <span class="text-[10px] font-semibold px-2 py-0.5 rounded-full
                                    <%= order.status === 'Delivered' ? 'bg-emerald-50 text-emerald-600' :
                                       order.status === 'Cancelled' ? 'bg-red-50 text-red-600' :
                                       order.status === 'Shipped' || order.status === 'Out For Delivery' ? 'bg-blue-50 text-blue-600' :
                                       'bg-amber-50 text-amber-600' %>
                                "><%= order.status %></span>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="px-6 py-10 text-center">
                        <i class="ri-file-list-3-line text-3xl text-dark-200 mb-2"></i>
                        <p class="text-sm text-dark-400">No orders yet</p>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Quick Stats -->
        <div>
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-bold text-dark-900">Order Summary</h2>
            </div>
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                <div class="flex items-center gap-4 px-5 py-4 border-b border-gray-50 hover:bg-gray-50/50 transition-colors">
                    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-amber-100 to-amber-200 flex items-center justify-center flex-shrink-0">
                        <i class="ri-time-line text-amber-600"></i>
                    </div>
                    <div class="min-w-0 flex-1">
                        <p class="text-sm font-semibold text-dark-800">Pending Orders</p>
                        <p class="text-xs text-dark-400">Awaiting processing</p>
                    </div>
                    <div class="text-right flex-shrink-0">
                        <p class="text-xl font-bold text-amber-600"><%= pendingOrders %></p>
                    </div>
                </div>
                <div class="flex items-center gap-4 px-5 py-4 border-b border-gray-50 hover:bg-gray-50/50 transition-colors">
                    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-emerald-100 to-emerald-200 flex items-center justify-center flex-shrink-0">
                        <i class="ri-checkbox-circle-line text-emerald-600"></i>
                    </div>
                    <div class="min-w-0 flex-1">
                        <p class="text-sm font-semibold text-dark-800">Delivered Orders</p>
                        <p class="text-xs text-dark-400">Successfully completed</p>
                    </div>
                    <div class="text-right flex-shrink-0">
                        <p class="text-xl font-bold text-emerald-600"><%= deliveredOrders %></p>
                    </div>
                </div>
                <div class="flex items-center gap-4 px-5 py-4 hover:bg-gray-50/50 transition-colors">
                    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-100 to-blue-200 flex items-center justify-center flex-shrink-0">
                        <i class="ri-truck-line text-blue-600"></i>
                    </div>
                    <div class="min-w-0 flex-1">
                        <p class="text-sm font-semibold text-dark-800">Total Orders</p>
                        <p class="text-xs text-dark-400">All time orders</p>
                    </div>
                    <div class="text-right flex-shrink-0">
                        <p class="text-xl font-bold text-blue-600"><%= totalOrders %></p>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- Dashboard Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

        <!-- Create Product -->
        <a href="/sellers/products/create"
            class="group bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 p-6 border border-gray-100">

            <div class="w-14 h-14 rounded-xl bg-orange-100 flex items-center justify-center mb-5">
                <i class="ri-add-circle-fill text-3xl text-orange-500"></i>
            </div>

            <h2 class="text-xl font-semibold text-gray-800 group-hover:text-orange-500">
                Add Product
            </h2>

            <p class="text-gray-500 mt-2 text-sm">
                Add a new product to your store.
            </p>

        </a>

        <!-- Products -->
        <a href="/sellers/products"
            class="group bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 p-6 border border-gray-100">

            <div class="w-14 h-14 rounded-xl bg-blue-100 flex items-center justify-center mb-5">
                <i class="ri-shopping-bag-3-fill text-3xl text-blue-500"></i>
            </div>

            <h2 class="text-xl font-semibold text-gray-800 group-hover:text-blue-500">
                My Products
            </h2>

            <p class="text-gray-500 mt-2 text-sm">
                View, edit and delete products.
            </p>

        </a>

        <!-- Orders -->
        <a href="/sellers/orders"
            class="group bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 p-6 border border-gray-100">

            <div class="w-14 h-14 rounded-xl bg-green-100 flex items-center justify-center mb-5">
                <i class="ri-file-list-3-fill text-3xl text-green-500"></i>
            </div>

            <h2 class="text-xl font-semibold text-gray-800 group-hover:text-green-500">
                Orders
            </h2>

            <p class="text-gray-500 mt-2 text-sm">
                Track and manage customer orders.
            </p>

        </a>

        <!-- Analytics -->
        <a href="/sellers/analytics"
            class="group bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 p-6 border border-gray-100">

            <div class="w-14 h-14 rounded-xl bg-purple-100 flex items-center justify-center mb-5">
                <i class="ri-bar-chart-box-fill text-3xl text-purple-500"></i>
            </div>

            <h2 class="text-xl font-semibold text-gray-800 group-hover:text-purple-500">
                Analytics
            </h2>

            <p class="text-gray-500 mt-2 text-sm">
                View store performance insights.
            </p>

        </a>

    </div>

</div>

<%- include('./partials/footer') %>
