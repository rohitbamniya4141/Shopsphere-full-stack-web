<%- include('./partials/admin-header') %>

    <!-- Flash Success -->
    <% if(success.length > 0){ %>
        <div class="flash-message fixed top-20 left-1/2 -translate-x-1/2 z-50 px-8 py-4 rounded-2xl bg-emerald-500/95 backdrop-blur-md shadow-2xl shadow-emerald-500/25">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0">
                    <i class="ri-check-line text-white text-lg"></i>
                </div>
                <span class="text-white text-sm font-semibold tracking-wide"><%= success %></span>
            </div>
        </div>
    <% } %>

    <div class="max-w-7xl mx-auto px-5 sm:px-6 md:px-10 lg:px-16 xl:px-20 py-8 md:py-12">
        <div class="flex flex-col lg:flex-row gap-8 lg:gap-10">

            <!-- Admin Sidebar -->
            <aside class="hidden lg:block w-[260px] flex-shrink-0">
                <div class="bg-white rounded-2xl border border-gray-100/80 shadow-lg shadow-black/[0.03] p-6 sticky top-24">
                    <div class="flex items-center gap-3.5 mb-6 pb-6 border-b border-gray-100">
                        <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center shadow-md shadow-brand-500/20">
                            <i class="ri-settings-3-line text-white text-xl"></i>
                        </div>
                        <div>
                            <h3 class="text-sm font-bold text-dark-900 tracking-tight">Admin Panel</h3>
                            <p class="text-[11px] text-dark-400 mt-0.5">Manage your store</p>
                        </div>
                    </div>

                    <div class="space-y-1">
                        <a href="/owners/admin" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-gradient-to-r from-brand-50 to-brand-100/50 text-brand-700 text-sm font-semibold border border-brand-200/40 shadow-sm shadow-brand-500/5 transition-all">
                            <i class="ri-add-circle-line text-base"></i> Create Product
                        </a>
                        <a href="#" class="flex items-center gap-3 px-4 py-3 rounded-xl text-dark-500 hover:bg-gray-50 hover:text-dark-700 text-sm font-medium transition-all duration-200">
                            <i class="ri-list-check-2 text-base"></i> All Products
                        </a>
                        <a href="#" class="flex items-center gap-3 px-4 py-3 rounded-xl text-dark-500 hover:bg-gray-50 hover:text-dark-700 text-sm font-medium transition-all duration-200">
                            <i class="ri-bar-chart-box-line text-base"></i> Analytics
                        </a>
                    </div>

                    <div class="mt-6 pt-5 border-t border-gray-100">
                        <a href="/shop" class="flex items-center gap-2 text-xs text-dark-400 hover:text-brand-600 transition-colors font-medium">
                            <i class="ri-arrow-left-s-line"></i> Back to Store
                        </a>
                    </div>
                </div>
            </aside>

            <!-- Main Content -->
            <main class="flex-1 min-w-0 animate-fade-in-up">

                <!-- Page Header -->
                <div class="mb-8">
                    <div class="flex items-center gap-2.5 mb-3">
                        <div class="w-1.5 h-6 rounded-full bg-gradient-to-b from-brand-400 to-brand-600"></div>
                        <p class="text-brand-600 text-xs font-bold uppercase tracking-[0.15em]">Admin Dashboard</p>
                    </div>
                    <h1 class="text-2xl sm:text-3xl lg:text-[2rem] font-serif font-bold text-dark-900 tracking-tight leading-tight">Create New Product</h1>
                    <p class="text-dark-400 text-sm mt-1.5 leading-relaxed">Add a new item to your store catalog</p>
                </div>

                <!-- Dashboard Stats -->
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 md:gap-5 mb-10">

                    <div class="group bg-white rounded-2xl border border-gray-100/80 shadow-sm hover:shadow-lg hover:shadow-blue-500/[0.04] p-5 md:p-6 transition-all duration-300 hover:-translate-y-0.5">
                        <div class="flex items-center justify-between mb-3">
                            <p class="text-dark-400 text-xs font-semibold uppercase tracking-wider">Total Products</p>
                            <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                                <i class="ri-shopping-bag-3-line text-blue-500 text-lg"></i>
                            </div>
                        </div>
                        <h2 class="text-3xl font-extrabold text-dark-900 tracking-tight"><%= totalProducts %></h2>
                        <p class="text-[11px] text-dark-300 mt-1.5 font-medium">Active items in catalog</p>
                    </div>

                    <div class="group bg-white rounded-2xl border border-gray-100/80 shadow-sm hover:shadow-lg hover:shadow-purple-500/[0.04] p-5 md:p-6 transition-all duration-300 hover:-translate-y-0.5">
                        <div class="flex items-center justify-between mb-3">
                            <p class="text-dark-400 text-xs font-semibold uppercase tracking-wider">Total Orders</p>
                            <div class="w-10 h-10 rounded-xl bg-purple-50 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                                <i class="ri-file-list-3-line text-purple-500 text-lg"></i>
                            </div>
                        </div>
                        <h2 class="text-3xl font-extrabold text-dark-900 tracking-tight"><%= totalOrders %></h2>
                        <p class="text-[11px] text-dark-300 mt-1.5 font-medium">Completed transactions</p>
                    </div>

                    <div class="group bg-white rounded-2xl border border-gray-100/80 shadow-sm hover:shadow-lg hover:shadow-emerald-500/[0.04] p-5 md:p-6 transition-all duration-300 hover:-translate-y-0.5">
                        <div class="flex items-center justify-between mb-3">
                            <p class="text-dark-400 text-xs font-semibold uppercase tracking-wider">Revenue</p>
                            <div class="w-10 h-10 rounded-xl bg-emerald-50 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                                <i class="ri-money-rupee-circle-line text-emerald-500 text-lg"></i>
                            </div>
                        </div>
                        <h2 class="text-3xl font-extrabold text-emerald-600 tracking-tight">₹<%= revenue %></h2>
                        <p class="text-[11px] text-dark-300 mt-1.5 font-medium">Total revenue earned</p>
                    </div>

                </div>

                <!-- Create Product Form -->
                <div class="bg-white rounded-2xl border border-gray-100/80 shadow-lg shadow-black/[0.03] overflow-hidden">

                    <!-- Form Header -->
                    <div class="px-6 md:px-8 pt-7 pb-5 border-b border-gray-100/80 bg-gradient-to-r from-gray-50/50 to-white">
                        <h2 class="text-base font-bold text-dark-900 flex items-center gap-2.5">
                            <div class="w-8 h-8 rounded-lg bg-brand-50 flex items-center justify-center">
                                <i class="ri-add-circle-line text-brand-600 text-base"></i>
                            </div>
                            New Product
                        </h2>
                    </div>

                    <form autocomplete="off" action="/products/create" method="post" enctype="multipart/form-data" class="p-6 md:p-8">

                        <!-- Product Image -->
                        <div class="mb-8">
                            <label class="text-xs font-bold uppercase tracking-[0.12em] text-dark-500 mb-3 block flex items-center gap-2">
                                <i class="ri-image-line text-brand-400 text-sm"></i> Product Image
                            </label>
                            <div class="border-2 border-dashed border-gray-200 rounded-2xl p-8 sm:p-10 text-center hover:border-brand-400 hover:bg-brand-50/20 transition-all duration-300 cursor-pointer group">
                                <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-50 to-brand-100 flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300 shadow-sm">
                                    <i class="ri-image-add-line text-2xl text-brand-500"></i>
                                </div>
                                <p class="text-sm font-semibold text-dark-600 mb-2">Drop your image here or browse</p>
                                <input name="image" type="file" class="text-sm text-dark-500 file:mr-4 file:py-2.5 file:px-6 file:rounded-full file:border-0 file:text-xs file:font-bold file:uppercase file:tracking-wider file:bg-brand-500 file:text-white hover:file:bg-brand-600 file:cursor-pointer file:shadow-md file:shadow-brand-500/20 cursor-pointer file:transition-all file:duration-200" accept="image/*">
                                <p class="text-[11px] text-dark-300 mt-3 font-medium">PNG, JPG, WEBP up to 5MB</p>
                            </div>
                        </div>

                        <!-- Product Details Section -->
                        <div class="mb-8">
                            <h3 class="text-xs font-bold text-dark-800 mb-5 flex items-center gap-2.5 uppercase tracking-[0.12em]">
                                <div class="w-6 h-6 rounded-md bg-blue-50 flex items-center justify-center">
                                    <i class="ri-information-line text-blue-500 text-xs"></i>
                                </div>
                                Product Details
                            </h3>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                                <div class="md:col-span-2">
                                    <label class="text-[11px] font-semibold text-dark-400 uppercase tracking-[0.12em] mb-2 block">Product Name</label>
                                    <input name="name" type="text" placeholder="e.g. Classic Leather Tote"
                                        class="input-styled w-full px-4 py-3.5 rounded-xl bg-gray-50/70 text-dark-900 placeholder-dark-300 text-sm font-medium">
                                </div>
                                <div>
                                    <label class="text-[11px] font-semibold text-dark-400 uppercase tracking-[0.12em] mb-2 block">Price (₹)</label>
                                    <input name="price" type="text" placeholder="e.g. 2499"
                                        class="input-styled w-full px-4 py-3.5 rounded-xl bg-gray-50/70 text-dark-900 placeholder-dark-300 text-sm font-medium">
                                </div>
                                <div>
                                    <label class="text-[11px] font-semibold text-dark-400 uppercase tracking-[0.12em] mb-2 block">Discount (₹)</label>
                                    <input name="discount" type="text" placeholder="e.g. 200"
                                        class="input-styled w-full px-4 py-3.5 rounded-xl bg-gray-50/70 text-dark-900 placeholder-dark-300 text-sm font-medium">
                                </div>
                                <div>
                                    <label class="text-[11px] font-semibold text-dark-400 uppercase tracking-[0.12em] mb-2 block">Category</label>
                                    <select name="category" class="input-styled w-full px-4 py-3.5 rounded-xl bg-gray-50/70 text-dark-900 text-sm font-medium">
                                        <option value="General">General</option>
                                        <option value="Handbags">Handbags</option>
                                        <option value="Backpacks">Backpacks</option>
                                        <option value="Clutches">Clutches</option>
                                        <option value="Tote Bags">Tote Bags</option>
                                        <option value="Crossbody">Crossbody</option>
                                        <option value="Wallets">Wallets</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="text-[11px] font-semibold text-dark-400 uppercase tracking-[0.12em] mb-2 block">Stock Quantity</label>
                                    <input name="stock" type="number" placeholder="e.g. 25" min="0"
                                        class="input-styled w-full px-4 py-3.5 rounded-xl bg-gray-50/70 text-dark-900 placeholder-dark-300 text-sm font-medium">
                                </div>
                            </div>
                        </div>

                        <!-- Panel Customization Section -->
                        <div class="mb-8">
                            <h3 class="text-xs font-bold text-dark-800 mb-5 flex items-center gap-2.5 uppercase tracking-[0.12em]">
                                <div class="w-6 h-6 rounded-md bg-purple-50 flex items-center justify-center">
                                    <i class="ri-palette-line text-purple-500 text-xs"></i>
                                </div>
                                Display Colors
                            </h3>
                            <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
                                <div>
                                    <label class="text-[11px] font-semibold text-dark-400 uppercase tracking-[0.12em] mb-2 block">Background Color</label>
                                    <input name="bgcolor" type="text" placeholder="e.g. #f5f0eb"
                                        class="input-styled w-full px-4 py-3.5 rounded-xl bg-gray-50/70 text-dark-900 placeholder-dark-300 text-sm font-medium font-mono">
                                </div>
                                <div>
                                    <label class="text-[11px] font-semibold text-dark-400 uppercase tracking-[0.12em] mb-2 block">Panel Color</label>
                                    <input name="panelcolor" type="text" placeholder="e.g. #2d2d2d"
                                        class="input-styled w-full px-4 py-3.5 rounded-xl bg-gray-50/70 text-dark-900 placeholder-dark-300 text-sm font-medium font-mono">
                                </div>
                                <div>
                                    <label class="text-[11px] font-semibold text-dark-400 uppercase tracking-[0.12em] mb-2 block">Text Color</label>
                                    <input name="textcolor" type="text" placeholder="e.g. #ffffff"
                                        class="input-styled w-full px-4 py-3.5 rounded-xl bg-gray-50/70 text-dark-900 placeholder-dark-300 text-sm font-medium font-mono">
                                </div>
                            </div>
                        </div>

                        <!-- Divider -->
                        <div class="border-t border-gray-100 my-6"></div>

                        <!-- Submit Buttons -->
                        <div class="flex flex-col sm:flex-row items-center gap-3 sm:gap-4">
                            <button type="submit" class="w-full sm:w-auto btn-primary text-white font-bold px-10 py-3.5 rounded-xl text-sm tracking-wide inline-flex items-center justify-center gap-2.5">
                                <i class="ri-add-line text-base"></i>
                                Create Product
                            </button>
                            <a href="/shop" class="w-full sm:w-auto text-center px-8 py-3.5 rounded-xl border border-gray-200 text-dark-500 text-sm font-semibold hover:bg-gray-50 hover:border-gray-300 hover:text-dark-700 transition-all duration-200">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>

                <!-- Product List -->
                <div class="mt-12">

                    <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-6 gap-3">
                        <div>
                            <h2 class="text-xl sm:text-2xl font-bold text-dark-900 tracking-tight">All Products</h2>
                            <p class="text-dark-400 text-sm mt-0.5">
                                <span class="inline-flex items-center gap-1.5">
                                    <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
                                    <span class="font-medium">Total Products : <%= products.length %></span>
                                </span>
                            </p>
                        </div>
                    </div>

                    <div class="space-y-3">

                        <% products.forEach(function(product){ %>

                            <div class="group bg-white rounded-2xl border border-gray-100/80 shadow-sm hover:shadow-lg hover:shadow-black/[0.05] p-4 sm:p-5 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 transition-all duration-300 hover:-translate-y-0.5">

                                <div class="flex items-center gap-4 sm:gap-5">

                                    <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-xl flex items-center justify-center overflow-hidden flex-shrink-0 shadow-sm group-hover:shadow-md transition-shadow duration-300"
                                        style="background:<%= product.bgcolor %>">
                                        <img
                                            class="h-12 sm:h-16 object-contain group-hover:scale-105 transition-transform duration-300"
                                            src="<%= product.image %>" alt="<%= product.name %>">
                                    </div>

                                    <div>
                                        <h3 class="font-bold text-base sm:text-lg text-dark-900 tracking-tight">
                                            <%= product.name %>
                                        </h3>
                                        <p class="text-dark-500 text-sm font-semibold mt-0.5">
                                            ₹<%= product.price %>
                                        </p>
                                        <% if(product.discount>0){ %>
                                            <span class="inline-flex items-center gap-1 mt-1 px-2.5 py-0.5 rounded-full bg-emerald-50 text-emerald-600 text-xs font-bold">
                                                <i class="ri-price-tag-3-line text-[10px]"></i>
                                                Discount ₹<%= product.discount %>
                                            </span>
                                        <% } %>
                                    </div>

                                </div>

                                <div class="flex gap-2 sm:gap-2.5 w-full sm:w-auto">

                                    <a href="/owners/edit/<%= product._id %>"
                                        class="flex-1 sm:flex-none inline-flex items-center justify-center gap-1.5 px-5 py-2.5 rounded-xl bg-dark-900 hover:bg-dark-800 text-white text-xs font-bold uppercase tracking-wider transition-all duration-200 hover:shadow-lg hover:shadow-dark-900/20">
                                        <i class="ri-edit-line text-sm"></i>
                                        Edit
                                    </a>

                                    <a href="/owners/delete/<%= product._id %>"
                                        class="flex-1 sm:flex-none inline-flex items-center justify-center gap-1.5 px-5 py-2.5 rounded-xl bg-white border-2 border-red-200 text-red-500 hover:bg-red-500 hover:text-white hover:border-red-500 text-xs font-bold uppercase tracking-wider transition-all duration-200 hover:shadow-lg hover:shadow-red-500/20">
                                        <i class="ri-delete-bin-line text-sm"></i>
                                        Delete
                                    </a>

                                </div>

                            </div>

                        <% }) %>

                    </div>

                </div>
            </main>
        </div>
    </div>

<%- include('./partials/footer') %>