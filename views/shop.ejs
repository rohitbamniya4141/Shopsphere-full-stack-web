<%- include('./partials/header') %>

    <!-- Flash Success -->
    <% if(success.length > 0){ %>
        <div class="flash-message fixed top-20 left-1/2 -translate-x-1/2 z-50 px-6 py-3 rounded-xl bg-emerald-500/95 backdrop-blur-sm shadow-lg shadow-emerald-500/20">
            <div class="flex items-center gap-2">
                <i class="ri-check-line text-white text-lg"></i>
                <span class="text-white text-sm font-medium"><%= success %></span>
            </div>
        </div>
    <% } %>

    <!-- Sticky Header Section -->
    <div class="sticky top-[72px] z-40 bg-[#fafaf9]/95 backdrop-blur-md border-b border-gray-100/80 pt-8 pb-6 px-4 sm:px-6 lg:px-10">
        <div class="max-w-7xl mx-auto">

            <!-- Page Title Row -->
            <div class="flex items-end justify-between mb-6 animate-fade-in-up">
                <div>
                    <p class="text-brand-600 text-xs sm:text-sm font-semibold uppercase tracking-[0.2em] mb-1.5">Our Collection</p>
                    <h1 class="text-2xl sm:text-3xl md:text-4xl font-serif font-bold text-dark-900 tracking-tight">Premium Bags</h1>
                </div>
                <div class="hidden md:flex items-center gap-2 text-dark-400">
                    <div class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></div>
                    <p class="text-sm font-medium"><%= products.length %> products found</p>
                </div>
            </div>

            <!-- Full-Width Search Bar -->
            <div class="animate-fade-in-up stagger-1">
                <form action="/shop" method="GET">
                    <input type="hidden" name="sort" value="<%= sort %>">
                    <input type="hidden" name="price" value="<%= price %>">

                    <div class="flex gap-2 sm:gap-3">
                        <div class="relative flex-1">
                            <i class="ri-search-line absolute left-4 sm:left-5 top-1/2 -translate-y-1/2 text-dark-300 text-lg sm:text-xl pointer-events-none"></i>
                            <input
                                type="text"
                                name="search"
                                value="<%= search %>"
                                placeholder="Search premium bags..."
                                class="w-full input-styled pl-12 sm:pl-14 pr-5 py-3.5 sm:py-4 rounded-2xl bg-white text-sm sm:text-lg placeholder:text-dark-300 text-dark-800 font-medium">
                        </div>
                        <button
                            type="submit"
                            class="btn-primary px-5 sm:px-8 rounded-2xl text-white font-semibold text-sm sm:text-base flex items-center gap-2 whitespace-nowrap">
                            <i class="ri-search-line sm:hidden"></i>
                            <span class="hidden sm:inline">Search</span>
                            <span class="sm:hidden">Go</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Main Content: Sidebar + Grid -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-10 py-8 lg:py-10">
        <div class="flex gap-8 lg:gap-10">

            <!-- ====== LEFT SIDEBAR ====== -->
            <aside class="hidden lg:block w-60 xl:w-64 flex-shrink-0 animate-fade-in-up stagger-1">
                <div class="sticky top-[260px] space-y-8">

                    <!-- Sort By -->
                    <div>
                        <h4 class="text-[11px] font-bold uppercase tracking-[0.15em] text-dark-400 mb-3 flex items-center gap-2">
                            <i class="ri-arrow-up-down-line text-sm text-brand-500"></i>
                            Sort By
                        </h4>
                        <form action="/shop" method="GET">
                            <input type="hidden" name="search" value="<%= search %>">
                            <input type="hidden" name="price" value="<%= price %>">
                            <select
                                name="sort"
                                onchange="this.form.submit()"
                                class="w-full px-4 py-2.5 rounded-xl border border-gray-200 bg-white text-sm text-dark-700 font-medium cursor-pointer hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-100 outline-none transition-all appearance-none"
                                style="background-image: url('data:image/svg+xml;charset=UTF-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 24 24%22%3E%3Cpath fill=%22%239da2ac%22 d=%22M12 16l-6-6h12z%22/%3E%3C/svg%3E'); background-repeat: no-repeat; background-position: right 12px center;">
                                <option value="popular" <%= sort=="popular"?"selected":"" %>>
                                    Popular
                                </option>
                                <option value="newest" <%= sort=="newest"?"selected":"" %>>
                                    Newest
                                </option>
                                <option value="price-low" <%= sort=="price-low"?"selected":"" %>>
                                    Price: Low to High
                                </option>
                                <option value="price-high" <%= sort=="price-high"?"selected":"" %>>
                                    Price: High to Low
                                </option>
                            </select>
                        </form>
                    </div>

                    <!-- Categories -->
                    <div>
                        <h4 class="text-[11px] font-bold uppercase tracking-[0.15em] text-dark-400 mb-4 flex items-center gap-2">
                            <i class="ri-layout-grid-line text-sm text-brand-500"></i>
                            Categories
                        </h4>
                        <div class="space-y-1">
                            <a href="/shop?search=<%= search %>&sort=<%= sort %>&price=<%= price %>" class="flex items-center gap-3 px-4 py-2.5 rounded-xl <%= !category ? 'bg-gradient-to-r from-brand-50 to-brand-100/60 text-brand-700 font-semibold border border-brand-200/50 shadow-sm' : 'text-dark-500 hover:bg-gray-50 hover:text-dark-700 font-medium' %> text-sm transition-all duration-200">
                                <i class="ri-handbag-line text-base"></i> All Bags
                            </a>
                            <% if(typeof categories !== 'undefined'){ %>
                                <% categories.forEach(function(cat){ %>
                                    <a href="/shop?category=<%= cat %>&search=<%= search %>&sort=<%= sort %>&price=<%= price %>" class="flex items-center gap-3 px-4 py-2.5 rounded-xl <%= category === cat ? 'bg-gradient-to-r from-brand-50 to-brand-100/60 text-brand-700 font-semibold border border-brand-200/50 shadow-sm' : 'text-dark-500 hover:bg-gray-50 hover:text-dark-700 font-medium' %> text-sm transition-all duration-200">
                                        <i class="ri-price-tag-3-line text-base text-dark-400"></i> <%= cat %>
                                    </a>
                                <% }) %>
                            <% } %>
                        </div>
                    </div>

                    <!-- Price Filter -->
                    <div>
                        <h4 class="text-[11px] font-bold uppercase tracking-[0.15em] text-dark-400 mb-3 flex items-center gap-2">
                            <i class="ri-money-dollar-circle-line text-sm text-brand-500"></i>
                            Price Filter
                        </h4>
                        <form action="/shop" method="GET">
                            <input type="hidden" name="search" value="<%= search %>">
                            <input type="hidden" name="sort" value="<%= sort %>">
                            <select
                                name="price"
                                onchange="this.form.submit()"
                                class="w-full px-4 py-2.5 rounded-xl border border-gray-200 bg-white text-sm text-dark-700 font-medium cursor-pointer hover:border-brand-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-100 outline-none transition-all appearance-none"
                                style="background-image: url('data:image/svg+xml;charset=UTF-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 24 24%22%3E%3Cpath fill=%22%239da2ac%22 d=%22M12 16l-6-6h12z%22/%3E%3C/svg%3E'); background-repeat: no-repeat; background-position: right 12px center;">
                                <option value="" <%= price=="" ? "selected" : "" %>>
                                    All Prices
                                </option>
                                <option value="0-1000" <%= price=="0-1000" ? "selected" : "" %>>
                                    ₹0 - ₹1000
                                </option>
                                <option value="1000-3000" <%= price=="1000-3000" ? "selected" : "" %>>
                                    ₹1000 - ₹3000
                                </option>
                                <option value="3000+" <%= price=="3000+" ? "selected" : "" %>>
                                    ₹3000+
                                </option>
                            </select>
                        </form>
                    </div>

                    <!-- Decorative Divider -->
                    <div class="pt-4 border-t border-gray-100">
                        <div class="flex items-center gap-3 text-dark-300 text-xs">
                            <i class="ri-shield-check-line text-emerald-500"></i>
                            <span>100% Authentic Products</span>
                        </div>
                        <div class="flex items-center gap-3 text-dark-300 text-xs mt-2">
                            <i class="ri-truck-line text-brand-500"></i>
                            <span>Free Shipping over ₹2000</span>
                        </div>
                    </div>
                </div>
            </aside>

            <!-- ====== PRODUCT GRID ====== -->
            <div class="flex-1 min-w-0">

                <!-- Mobile product count -->
                <div class="flex items-center justify-between mb-5 md:hidden">
                    <p class="text-dark-400 text-sm font-medium"><%= products.length %> products</p>
                </div>

                <% if(products.length === 0){ %>
                    <!-- Empty State -->
                    <div class="flex flex-col items-center justify-center py-24 animate-fade-in-up">
                        <div class="w-24 h-24 rounded-full bg-gradient-to-br from-gray-50 to-gray-100 flex items-center justify-center mb-6 shadow-inner">
                            <i class="ri-shopping-bag-line text-4xl text-dark-300"></i>
                        </div>
                        <h3 class="text-xl font-semibold text-dark-700 mb-2 font-serif">No products yet</h3>
                        <p class="text-dark-400 text-sm max-w-xs text-center leading-relaxed">Check back soon for new arrivals in our premium collection!</p>
                    </div>
                <% } else { %>
                    <!-- Products -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
                        <% products.forEach(function(product, index){ %>
                            <div class="product-card group rounded-2xl overflow-hidden bg-white shadow-sm border border-gray-100/80 animate-fade-in-up"
                                 style="animation-delay: <%= index * 0.08 %>s; opacity: 0;">

                                <!-- Product Image -->
                                <a href="/product/<%= product._id %>" class="block relative h-56 flex items-center justify-center overflow-hidden" style="background-color: <%= product.bgcolor %>">
                                    <img class="product-image h-[12rem] w-auto object-contain drop-shadow-lg"
                                         src="<%= product.image %>" alt="<%= product.name %>"
                                         alt="<%= product.name %>">

                                    <% if(product.discount > 0){ %>
                                        <div class="absolute top-3 left-3 px-3 py-1 rounded-full bg-red-500 text-white text-[11px] font-bold shadow-lg shadow-red-500/30 flex items-center gap-1">
                                            <i class="ri-discount-percent-line text-xs"></i>
                                            -₹<%= product.discount %> OFF
                                        </div>
                                    <% } %>

                                    <% if(product.stock <= 0){ %>
                                        <div class="absolute top-3 right-3 px-3 py-1 rounded-full bg-dark-900/80 text-white text-[11px] font-bold shadow-lg">
                                            Out of Stock
                                        </div>
                                    <% } %>

                                    <!-- Quick View Overlay -->
                                    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors duration-300"></div>
                                </a>

                                <!-- Product Info -->
                                <div class="p-5" style="background-color: <%= product.panelcolor %>; color: <%= product.textcolor %>">
                                    <div class="flex justify-between items-start gap-3">
                                        <div class="min-w-0">
                                            <a href="/product/<%= product._id %>" class="hover:opacity-80 transition-opacity">
                                                <h3 class="font-semibold text-[15px] mb-0.5 truncate"><%= product.name %></h3>
                                            </a>
                                            <p class="text-[10px] text-dark-400 mb-1.5 truncate">
                                                <i class="ri-store-2-line"></i>
                                                <%= product.seller && product.seller.shopName ? product.seller.shopName : 'ShopSphere Official' %>
                                            </p>
                                            <div class="flex items-baseline gap-2">
                                                <span class="text-lg font-bold tracking-tight">₹ <%= product.price - (product.discount || 0) %></span>
                                                <% if(product.discount > 0){ %>
                                                    <span class="text-sm line-through opacity-40 font-medium">₹ <%= product.price %></span>
                                                <% } %>
                                            </div>
                                        </div>

                                        <!-- Add to Cart Button -->
                                        <% if(product.stock > 0){ %>
                                            <a href="/add-to-cart/<%= product._id %>"
                                               class="flex-shrink-0 w-10 h-10 flex items-center justify-center rounded-full bg-white text-dark-900 shadow-md hover:shadow-xl hover:scale-110 active:scale-95 transition-all duration-300"
                                               title="Add to Cart">
                                                <i class="ri-add-line text-lg"></i>
                                            </a>
                                        <% } else { %>
                                            <span class="flex-shrink-0 w-10 h-10 flex items-center justify-center rounded-full bg-gray-200 text-gray-400 cursor-not-allowed" title="Out of Stock">
                                                <i class="ri-close-line text-lg"></i>
                                            </span>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

<%- include('./partials/footer') %>