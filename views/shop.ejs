<%- include('./partials/header') %>

    <!-- Flash Success -->
    <% if(success.length > 0){ %>
        <div class="flash-message fixed top-20 left-1/2 -translate-x-1/2 z-50 px-6 py-3 rounded-xl bg-emerald-500/95 backdrop-blur-sm shadow-lg shadow-emerald-500/20">
            <div class="flex items-center gap-2">
                <i class="ri-check-line text-white text-lg"></i>
                <span class="text-white text-sm font-medium"><%= success %></span>
            </div>
        </div>
    <% } %>

    <div class="sticky top-[72px] z-40 bg-[#fafaf9] pb-6 px-6 md:px-0">
        <!-- Page Header -->
        <div class="flex items-end justify-between mb-10 animate-fade-in-up">
            <div>
                <p class="text-brand-600 text-sm font-semibold uppercase tracking-wider mb-2">Our Collection</p>
                <h1 class="text-3xl md:text-4xl font-serif font-bold text-dark-900">Premium Bags</h1>
            </div>
            <p class="text-dark-400 text-sm hidden md:block"><%= products.length %> products found</p>
        </div>
                    <!-- Search -->
            <div class="mb-10 animate-fade-in-up">

                <form action="/shop" method="GET">
                    <input type="hidden" name="sort" value="<%= sort %>">
                    <input type="hidden" name="price" value="<%= price %>">

                    <div class="flex gap-3">

                        <div class="relative flex-1">

                            <i class="ri-search-line absolute left-5 top-1/2 -translate-y-1/2 text-gray-400 text-xl"></i>

                            <input
                                type="text"
                                name="search"
                                value="<%= search %>"
                                placeholder="Search premium bags..."
                                class="w-full input-styled pl-14 pr-5 py-4 rounded-2xl bg-white text-lg">

                        </div>

                        <button
                            type="submit"
                            class="btn-primary px-8 rounded-2xl text-white font-semibold">

                            Search

                        </button>

                    </div>

                </form>

            </div>
        <div class="flex gap-10">
            <!-- Sidebar -->
            <aside class="hidden lg:block w-64 flex-shrink-0 sticky top-24 h-fit animate-fade-in-up stagger-1">
                <!-- Sort -->
                <div class="mb-8">

                    <h4 class="text-xs font-bold uppercase tracking-wider text-dark-400 mb-3">
                        Sort By
                    </h4>

                    <form action="/shop" method="GET">

                        <input type="hidden" name="search" value="<%= search %>">
                        <input type="hidden" name="price" value="<%= price %>">

                        <select
                            name="sort"
                            onchange="this.form.submit()"
                            class="w-full px-4 py-2.5 rounded-xl border border-gray-200 bg-white text-sm text-dark-700">

                            <option value="popular" <%= sort=="popular"?"selected":"" %>>
                                Popular
                            </option>

                            <option value="newest" <%= sort=="newest"?"selected":"" %>>
                                Newest
                            </option>

                            <option value="price-low" <%= sort=="price-low"?"selected":"" %>>
                                Price: Low to High
                            </option>

                            <option value="price-high" <%= sort=="price-high"?"selected":"" %>>
                                Price: High to Low
                            </option>

                        </select>

                    </form>

                </div>
                
                <!-- Categories -->
                <div class="mb-8">
                    <h4 class="text-xs font-bold uppercase tracking-wider text-dark-400 mb-4">Categories</h4>
                    <div class="space-y-2">
                        <a href="/shop" class="flex items-center gap-3 px-4 py-2.5 rounded-xl bg-brand-50 text-brand-700 text-sm font-medium">
                            <i class="ri-handbag-line"></i> All Bags
                        </a>
                        <a href="#" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-dark-500 hover:bg-gray-50 text-sm transition-colors">
                            <i class="ri-briefcase-line"></i> Handbags
                        </a>
                        <a href="#" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-dark-500 hover:bg-gray-50 text-sm transition-colors">
                            <i class="ri-luggage-cart-line"></i> Backpacks
                        </a>
                        <a href="#" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-dark-500 hover:bg-gray-50 text-sm transition-colors">
                            <i class="ri-wallet-3-line"></i> Clutches
                        </a>
                        <a href="#" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-dark-500 hover:bg-gray-50 text-sm transition-colors">
                            <i class="ri-shopping-bag-line"></i> Tote Bags
                        </a>
                    </div>
                </div>

                                <!-- Price Filter -->
                <div class="mb-8">

                    <h4 class="text-xs font-bold uppercase tracking-wider text-dark-400 mb-4">
                        Price Filter
                    </h4>

                    <form action="/shop" method="GET">

                        <input type="hidden" name="search" value="<%= search %>">

                        <input type="hidden" name="sort" value="<%= sort %>">

                        <select
                            name="price"
                            onchange="this.form.submit()"
                            class="w-full px-4 py-2.5 rounded-xl border border-gray-200 bg-white text-sm text-dark-700">

                            <option value="" <%= price=="" ? "selected" : "" %>>
                                All Prices
                            </option>

                            <option value="0-1000" <%= price=="0-1000" ? "selected" : "" %>>
                                ₹0 - ₹1000
                            </option>

                            <option value="1000-3000" <%= price=="1000-3000" ? "selected" : "" %>>
                                ₹1000 - ₹3000
                            </option>

                            <option value="3000+" <%= price=="3000+" ? "selected" : "" %>>
                                ₹3000+
                            </option>

                        </select>

                    </form>

                </div>
            </aside>

            <!-- Product Grid -->
            <div class="flex-1">
                <% if(products.length === 0){ %>
                    <div class="flex flex-col items-center justify-center py-20">
                        <div class="w-20 h-20 rounded-full bg-gray-100 flex items-center justify-center mb-5">
                            <i class="ri-shopping-bag-line text-3xl text-dark-300"></i>
                        </div>
                        <h3 class="text-xl font-semibold text-dark-700 mb-2">No products yet</h3>
                        <p class="text-dark-400 text-sm">Check back soon for new arrivals!</p>
                    </div>
                <% } else { %>
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                        <% products.forEach(function(product, index){ %>
                            <div class="product-card rounded-2xl overflow-hidden bg-white shadow-sm border border-gray-100 animate-fade-in-up" style="animation-delay: <%= index * 0.08 %>s; opacity: 0;">
                                <!-- Product Image -->
                                <div class="relative h-56 flex items-center justify-center overflow-hidden" style="background-color: <%= product.bgcolor %>">
                                    <img class="product-image h-[12rem] object-contain drop-shadow-lg" 
                                         src="data:image/<%= product.image[0] === 0xFF ? 'jpeg' : product.image[0] === 0x89 ? 'png' : product.image.toString('utf8').includes('<svg') ? 'svg+xml' : 'jpeg' %>;base64,<%= product.image.toString('base64') %>"
                                         alt="<%= product.name %>">

                                    <% if(product.discount > 0){ %>
                                        <div class="absolute top-3 left-3 px-3 py-1 rounded-full bg-red-500 text-white text-xs font-bold shadow-md">
                                            -₹<%= product.discount %> OFF
                                        </div>
                                    <% } %>
                                </div>

                                <!-- Product Info -->
                                <div class="p-5" style="background-color: <%= product.panelcolor %>; color: <%= product.textcolor %>">
                                    <div class="flex justify-between items-start">
                                        <div>
                                            <h3 class="font-semibold text-base mb-1"><%= product.name %></h3>
                                            <div class="flex items-center gap-2">
                                                <span class="text-lg font-bold">₹ <%= product.price - (product.discount || 0) %></span>
                                                <% if(product.discount > 0){ %>
                                                    <span class="text-sm line-through opacity-50">₹ <%= product.price %></span>
                                                <% } %>
                                            </div>
                                        </div>
                                        <a href="/add-to-cart/<%= product._id %>" 
                                           class="w-10 h-10 flex items-center justify-center rounded-xl bg-white text-dark-900 shadow-md hover:shadow-lg hover:scale-110 transition-all"
                                           title="Add to Cart">
                                            <i class="ri-add-line text-lg"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

<%- include('./partials/footer') %>