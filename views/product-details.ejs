<%- include('./partials/header') %>

    <!-- Flash Messages -->
    <% if(typeof success !== 'undefined' && success.length > 0){ %>
        <div class="flash-message fixed top-20 left-1/2 -translate-x-1/2 z-50 px-6 py-3 rounded-xl bg-emerald-500/95 backdrop-blur-sm shadow-lg shadow-emerald-500/20">
            <div class="flex items-center gap-2">
                <i class="ri-check-line text-white text-lg"></i>
                <span class="text-white text-sm font-medium"><%= success %></span>
            </div>
        </div>
    <% } %>
    <% if(typeof error !== 'undefined' && error.length > 0){ %>
        <div class="flash-message fixed top-20 left-1/2 -translate-x-1/2 z-50 px-6 py-3 rounded-xl bg-red-500/95 backdrop-blur-sm shadow-lg shadow-red-500/20">
            <div class="flex items-center gap-2">
                <i class="ri-error-warning-line text-white text-lg"></i>
                <span class="text-white text-sm font-medium"><%= error %></span>
            </div>
        </div>
    <% } %>

    <!-- Breadcrumb -->
    <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12 pt-6 pb-2 animate-fade-in-up">
        <nav class="flex items-center gap-2 text-sm">
            <a href="/shop" class="text-dark-400 hover:text-brand-500 transition-colors font-medium">Shop</a>
            <i class="ri-arrow-right-s-line text-dark-300"></i>
            <span class="text-dark-700 font-semibold truncate max-w-[200px] sm:max-w-none"><%= product.name %></span>
        </nav>
    </div>

    <!-- ====== MAIN PRODUCT SECTION ====== -->
    <section class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12 py-8 lg:py-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-14">

            <!-- Left Column — Product Image -->
            <div class="animate-fade-in-up stagger-1">
                <div class="relative rounded-2xl overflow-hidden flex items-center justify-center aspect-square shadow-sm border border-gray-100/80"
                     style="background-color: <%= product.bgcolor %>">
                    <img class="h-[75%] w-auto object-contain drop-shadow-xl"
                         src="<%= product.image %>" alt="<%= product.name %>"
                         alt="<%= product.name %>">

                    <% if(product.discount > 0){ %>
                        <div class="absolute top-4 left-4 px-3.5 py-1.5 rounded-full bg-red-500 text-white text-xs font-bold shadow-lg shadow-red-500/30 flex items-center gap-1.5">
                            <i class="ri-discount-percent-line text-sm"></i>
                            -₹<%= product.discount %> OFF
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- Right Column — Product Info -->
            <div class="animate-fade-in-up stagger-2 flex flex-col gap-6">

                <!-- Product Name -->
                <div>
                    <h1 class="text-3xl sm:text-4xl font-serif font-bold text-dark-900 tracking-tight leading-tight mb-3">
                        <%= product.name %>
                    </h1>

                    <!-- Category Badge -->
                    <span class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full bg-brand-50 text-brand-700 text-xs font-semibold uppercase tracking-wider border border-brand-200/50">
                        <i class="ri-price-tag-3-line text-sm"></i>
                        <%= product.category %>
                    </span>

                    <!-- Sold By Badge -->
                    <% if(product.seller && product.seller.shopName){ %>
                        <a href="/seller/<%= product.seller._id %>" class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full bg-emerald-50 text-emerald-700 text-xs font-semibold border border-emerald-200/50 hover:bg-emerald-100 transition-colors">
                            <i class="ri-store-2-line text-sm"></i>
                            Sold by <%= product.seller.shopName %>
                        </a>
                    <% } else { %>
                        <span class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full bg-dark-50 text-dark-600 text-xs font-semibold border border-dark-200/50">
                            <i class="ri-verified-badge-line text-sm"></i>
                            Sold by ShopSphere Official
                        </span>
                    <% } %>
                </div>

                <!-- Star Rating Display -->
                <div class="flex items-center gap-3 flex-wrap">
                    <div class="flex items-center gap-0.5">
                        <% for(let i = 1; i <= 5; i++){ %>
                            <% if(i <= Math.floor(avgRating)){ %>
                                <i class="ri-star-fill text-xl text-amber-400"></i>
                            <% } else if(i === Math.floor(avgRating) + 1 && (avgRating % 1) >= 0.5){ %>
                                <i class="ri-star-half-fill text-xl text-amber-400"></i>
                            <% } else { %>
                                <i class="ri-star-line text-xl text-gray-300"></i>
                            <% } %>
                        <% } %>
                    </div>
                    <span class="text-lg font-bold text-dark-800"><%= avgRating %></span>
                    <span class="text-sm text-dark-400 font-medium">(<%= reviews.length %> <%= reviews.length === 1 ? 'review' : 'reviews' %>)</span>
                </div>

                <!-- Price -->
                <div class="flex items-baseline gap-3">
                    <span class="text-3xl font-bold text-dark-900 tracking-tight">₹<%= product.price - (product.discount || 0) %></span>
                    <% if(product.discount > 0){ %>
                        <span class="text-lg text-dark-400 line-through font-medium">₹<%= product.price %></span>
                        <span class="px-2.5 py-1 rounded-lg bg-emerald-50 text-emerald-600 text-xs font-bold">
                            Save ₹<%= product.discount %>
                        </span>
                    <% } %>
                </div>

                <!-- Stock Status -->
                <div>
                    <% if(product.stock > 0){ %>
                        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-emerald-50 text-emerald-700 text-sm font-semibold border border-emerald-200/50">
                            <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                            In Stock (<%= product.stock %>)
                        </span>
                    <% } else { %>
                        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-red-50 text-red-600 text-sm font-semibold border border-red-200/50">
                            <span class="w-2 h-2 rounded-full bg-red-500"></span>
                            Out of Stock
                        </span>
                    <% } %>
                </div>

                <!-- Divider -->
                <div class="h-px bg-gray-100"></div>

                <!-- Action Buttons -->
                <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3">

                    <!-- Add to Cart -->
                    <% if(product.stock > 0){ %>
                        <a href="/add-to-cart/<%= product._id %>"
                           class="btn-primary flex items-center justify-center gap-2.5 px-8 py-3.5 rounded-xl text-white font-semibold text-sm tracking-wide uppercase flex-1 sm:flex-none">
                            <i class="ri-shopping-bag-line text-lg"></i>
                            Add to Cart
                        </a>
                    <% } else { %>
                        <button disabled
                                class="flex items-center justify-center gap-2.5 px-8 py-3.5 rounded-xl bg-gray-200 text-gray-400 font-semibold text-sm tracking-wide uppercase cursor-not-allowed flex-1 sm:flex-none">
                            <i class="ri-shopping-bag-line text-lg"></i>
                            Out of Stock
                        </button>
                    <% } %>

                    <!-- Wishlist Button -->
                    <% if(inWishlist){ %>
                        <a href="/remove-from-wishlist/<%= product._id %>"
                           class="flex items-center justify-center gap-2 px-6 py-3.5 rounded-xl border-2 border-red-200 bg-red-50 text-red-500 font-semibold text-sm hover:bg-red-100 transition-all duration-300 group"
                           title="Remove from Wishlist">
                            <i class="ri-heart-fill text-xl group-hover:scale-110 transition-transform"></i>
                            <span class="sm:inline hidden">Wishlisted</span>
                        </a>
                    <% } else { %>
                        <a href="/add-to-wishlist/<%= product._id %>"
                           class="flex items-center justify-center gap-2 px-6 py-3.5 rounded-xl border-2 border-gray-200 bg-white text-dark-500 font-semibold text-sm hover:border-red-200 hover:text-red-500 hover:bg-red-50 transition-all duration-300 group"
                           title="Add to Wishlist">
                            <i class="ri-heart-line text-xl group-hover:scale-110 transition-transform"></i>
                            <span class="sm:inline hidden">Add to Wishlist</span>
                        </a>
                    <% } %>
                </div>

                <!-- Trust Badges -->
                <div class="grid grid-cols-3 gap-3 pt-2">
                    <div class="flex flex-col items-center gap-1.5 p-3 rounded-xl bg-gray-50/80 border border-gray-100">
                        <i class="ri-truck-line text-lg text-brand-500"></i>
                        <span class="text-[11px] text-dark-400 font-medium text-center">Free Shipping</span>
                    </div>
                    <div class="flex flex-col items-center gap-1.5 p-3 rounded-xl bg-gray-50/80 border border-gray-100">
                        <i class="ri-shield-check-line text-lg text-brand-500"></i>
                        <span class="text-[11px] text-dark-400 font-medium text-center">Genuine Product</span>
                    </div>
                    <div class="flex flex-col items-center gap-1.5 p-3 rounded-xl bg-gray-50/80 border border-gray-100">
                        <i class="ri-exchange-line text-lg text-brand-500"></i>
                        <span class="text-[11px] text-dark-400 font-medium text-center">Easy Returns</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ====== REVIEWS SECTION ====== -->
    <section class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12 py-8 lg:py-12">
        <div class="animate-fade-in-up stagger-3">

            <!-- Section Title -->
            <div class="flex items-center gap-3 mb-8">
                <h2 class="text-2xl sm:text-3xl font-serif font-bold text-dark-900 tracking-tight">Customer Reviews</h2>
                <span class="px-3 py-1 rounded-full bg-dark-100 text-dark-600 text-xs font-bold"><%= reviews.length %></span>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12">

                <!-- Left: Write a Review / Status -->
                <div class="lg:col-span-1">
                    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">

                        <% if(hasPurchased && !hasReviewed){ %>
                            <!-- Review Form -->
                            <h3 class="text-lg font-semibold text-dark-800 mb-1">Write a Review</h3>
                            <p class="text-sm text-dark-400 mb-5">Share your experience with this product</p>

                            <form action="/product/<%= product._id %>/review" method="POST" class="space-y-5">

                                <!-- Interactive Star Rating -->
                                <div>
                                    <label class="block text-sm font-semibold text-dark-700 mb-2">Your Rating</label>
                                    <div class="flex gap-1" id="star-rating">
                                        <% for(let i = 1; i <= 5; i++){ %>
                                            <label class="cursor-pointer">
                                                <input type="radio" name="rating" value="<%= i %>" class="hidden" required>
                                                <i class="ri-star-line text-2xl text-gray-300 hover:text-amber-400 transition-colors star-icon" data-value="<%= i %>"></i>
                                            </label>
                                        <% } %>
                                    </div>
                                </div>

                                <!-- Comment -->
                                <div>
                                    <label class="block text-sm font-semibold text-dark-700 mb-2">Your Review</label>
                                    <textarea
                                        name="comment"
                                        rows="4"
                                        required
                                        placeholder="Tell others what you think about this product..."
                                        class="w-full input-styled px-4 py-3 rounded-xl bg-gray-50/50 text-sm text-dark-800 placeholder:text-dark-300 resize-none"></textarea>
                                </div>

                                <!-- Submit -->
                                <button type="submit"
                                        class="btn-primary w-full py-3 rounded-xl text-white font-semibold text-sm tracking-wide uppercase flex items-center justify-center gap-2">
                                    <i class="ri-send-plane-line"></i>
                                    Submit Review
                                </button>
                            </form>

                        <% } else if(hasPurchased && hasReviewed){ %>
                            <!-- Already Reviewed -->
                            <div class="text-center py-6">
                                <div class="w-16 h-16 rounded-full bg-emerald-50 flex items-center justify-center mx-auto mb-4">
                                    <i class="ri-check-double-line text-3xl text-emerald-500"></i>
                                </div>
                                <h3 class="text-lg font-semibold text-dark-800 mb-2">Review Submitted</h3>
                                <p class="text-sm text-dark-400 leading-relaxed">You have already reviewed this product. Thank you for your feedback!</p>
                            </div>

                        <% } else { %>
                            <!-- Not Purchased -->
                            <div class="text-center py-6">
                                <div class="w-16 h-16 rounded-full bg-brand-50 flex items-center justify-center mx-auto mb-4">
                                    <i class="ri-shopping-bag-line text-3xl text-brand-500"></i>
                                </div>
                                <h3 class="text-lg font-semibold text-dark-800 mb-2">Purchase Required</h3>
                                <p class="text-sm text-dark-400 leading-relaxed">Purchase this product to leave a review and share your experience.</p>
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- Right: Reviews List -->
                <div class="lg:col-span-2">
                    <% if(reviews.length === 0){ %>
                        <!-- No Reviews -->
                        <div class="flex flex-col items-center justify-center py-16 bg-white rounded-2xl border border-gray-100 shadow-sm">
                            <div class="w-20 h-20 rounded-full bg-gradient-to-br from-gray-50 to-gray-100 flex items-center justify-center mb-5 shadow-inner">
                                <i class="ri-chat-3-line text-3xl text-dark-300"></i>
                            </div>
                            <h3 class="text-lg font-semibold text-dark-700 mb-1.5 font-serif">No Reviews Yet</h3>
                            <p class="text-sm text-dark-400 max-w-xs text-center">Be the first to share your thoughts about this product.</p>
                        </div>
                    <% } else { %>
                        <!-- Reviews List -->
                        <div class="space-y-4">
                            <% reviews.forEach(function(review, index){ %>
                                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 sm:p-6 hover:shadow-md transition-shadow duration-300"
                                     style="animation: fadeInUp 0.5s ease-out <%= index * 0.08 %>s forwards; opacity: 0;">

                                    <!-- Review Header -->
                                    <div class="flex items-start justify-between gap-3 mb-3">
                                        <div class="flex items-center gap-3">
                                            <!-- User Avatar -->
                                            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-brand-400 to-brand-600 flex items-center justify-center flex-shrink-0 shadow-sm">
                                                <span class="text-white text-sm font-bold uppercase"><%= review.user.fullname.charAt(0) %></span>
                                            </div>
                                            <div>
                                                <h4 class="text-sm font-semibold text-dark-800"><%= review.user.fullname %></h4>
                                                <p class="text-xs text-dark-400">
                                                    <%= new Date(review.createdAt).toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                                                </p>
                                            </div>
                                        </div>

                                        <!-- Star Rating -->
                                        <div class="flex items-center gap-0.5 flex-shrink-0">
                                            <% for(let i = 1; i <= 5; i++){ %>
                                                <% if(i <= review.rating){ %>
                                                    <i class="ri-star-fill text-sm text-amber-400"></i>
                                                <% } else { %>
                                                    <i class="ri-star-line text-sm text-gray-300"></i>
                                                <% } %>
                                            <% } %>
                                        </div>
                                    </div>

                                    <!-- Review Comment -->
                                    <p class="text-sm text-dark-600 leading-relaxed pl-[52px]"><%= review.comment %></p>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </section>

    <!-- ====== RELATED PRODUCTS ====== -->
    <% if(relatedProducts && relatedProducts.length > 0){ %>
        <section class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12 py-8 lg:py-12 border-t border-gray-100">
            <div class="animate-fade-in-up stagger-4">

                <!-- Section Title -->
                <div class="flex items-end justify-between mb-8">
                    <div>
                        <p class="text-brand-600 text-xs font-semibold uppercase tracking-[0.2em] mb-1.5">Similar Products</p>
                        <h2 class="text-2xl sm:text-3xl font-serif font-bold text-dark-900 tracking-tight">You May Also Like</h2>
                    </div>
                    <a href="/shop" class="hidden sm:flex items-center gap-1.5 text-sm font-semibold text-brand-600 hover:text-brand-700 transition-colors">
                        View All
                        <i class="ri-arrow-right-line text-base"></i>
                    </a>
                </div>

                <!-- Related Products Grid -->
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 lg:gap-6">
                    <% relatedProducts.forEach(function(p, index){ %>
                        <a href="/product/<%= p._id %>"
                           class="product-card group rounded-2xl overflow-hidden bg-white shadow-sm border border-gray-100/80 block"
                           style="animation: fadeInUp 0.5s ease-out <%= index * 0.1 %>s forwards; opacity: 0;">

                            <!-- Product Image -->
                            <div class="relative h-48 flex items-center justify-center overflow-hidden"
                                 style="background-color: <%= p.bgcolor %>">
                                <img class="product-image h-[10rem] w-auto object-contain drop-shadow-lg"
                                     src="<%= p.image %>"
                                     alt="<%= p.name %>">

                                <% if(p.discount > 0){ %>
                                    <div class="absolute top-3 left-3 px-2.5 py-1 rounded-full bg-red-500 text-white text-[10px] font-bold shadow-lg shadow-red-500/30">
                                        -₹<%= p.discount %> OFF
                                    </div>
                                <% } %>

                                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors duration-300"></div>
                            </div>

                            <!-- Product Info -->
                            <div class="p-4" style="background-color: <%= p.panelcolor %>; color: <%= p.textcolor %>">
                                <h3 class="font-semibold text-sm mb-1.5 truncate"><%= p.name %></h3>
                                <div class="flex items-baseline gap-2">
                                    <span class="text-base font-bold tracking-tight">₹<%= p.price - (p.discount || 0) %></span>
                                    <% if(p.discount > 0){ %>
                                        <span class="text-xs line-through opacity-40 font-medium">₹<%= p.price %></span>
                                    <% } %>
                                </div>
                            </div>
                        </a>
                    <% }) %>
                </div>

                <!-- Mobile View All -->
                <div class="flex sm:hidden justify-center mt-6">
                    <a href="/shop" class="btn-dark px-8 py-3 rounded-xl text-white text-sm font-semibold tracking-wide uppercase flex items-center gap-2">
                        View All Products
                        <i class="ri-arrow-right-line"></i>
                    </a>
                </div>
            </div>
        </section>
    <% } %>

    <!-- ====== INTERACTIVE STAR RATING SCRIPT ====== -->
    <script>
        // Interactive star rating for review form
        const starRating = document.getElementById('star-rating');
        if (starRating) {
            const stars = starRating.querySelectorAll('.star-icon');
            const radios = starRating.querySelectorAll('input[name="rating"]');

            stars.forEach(function(star) {
                star.addEventListener('click', function() {
                    const value = parseInt(this.getAttribute('data-value'));

                    // Check the corresponding radio
                    radios.forEach(function(radio) {
                        if (parseInt(radio.value) === value) {
                            radio.checked = true;
                        }
                    });

                    // Update star visuals
                    stars.forEach(function(s) {
                        const sValue = parseInt(s.getAttribute('data-value'));
                        if (sValue <= value) {
                            s.classList.remove('ri-star-line', 'text-gray-300');
                            s.classList.add('ri-star-fill', 'text-amber-400');
                        } else {
                            s.classList.remove('ri-star-fill', 'text-amber-400');
                            s.classList.add('ri-star-line', 'text-gray-300');
                        }
                    });
                });

                // Hover preview
                star.addEventListener('mouseenter', function() {
                    const value = parseInt(this.getAttribute('data-value'));
                    stars.forEach(function(s) {
                        const sValue = parseInt(s.getAttribute('data-value'));
                        if (sValue <= value) {
                            s.classList.add('text-amber-400');
                            s.classList.remove('text-gray-300');
                        }
                    });
                });
            });

            // Reset hover preview on mouse leave
            starRating.addEventListener('mouseleave', function() {
                const checkedRadio = starRating.querySelector('input[name="rating"]:checked');
                const checkedValue = checkedRadio ? parseInt(checkedRadio.value) : 0;

                stars.forEach(function(s) {
                    const sValue = parseInt(s.getAttribute('data-value'));
                    if (sValue <= checkedValue) {
                        s.classList.remove('ri-star-line', 'text-gray-300');
                        s.classList.add('ri-star-fill', 'text-amber-400');
                    } else {
                        s.classList.remove('ri-star-fill', 'text-amber-400');
                        s.classList.add('ri-star-line', 'text-gray-300');
                    }
                });
            });
        }

        // Auto-dismiss flash messages
        document.querySelectorAll('.flash-message').forEach(function(msg) {
            setTimeout(function() {
                msg.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
                msg.style.opacity = '0';
                msg.style.transform = 'translateX(-50%) translateY(-12px)';
                setTimeout(function() { msg.remove(); }, 400);
            }, 3000);
        });
    </script>

<%- include('./partials/footer') %>
