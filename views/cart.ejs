<%- include('./partials/header') %>

    <!-- Flash Success -->
    <% if(typeof success !== 'undefined' && success.length > 0){ %>
        <div class="flash-message fixed top-20 left-1/2 -translate-x-1/2 z-50 px-8 py-4 rounded-2xl bg-emerald-500/95 backdrop-blur-md shadow-2xl shadow-emerald-500/25">
            <div class="flex items-center gap-3">
                <div class="w-7 h-7 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0">
                    <i class="ri-check-line text-white text-sm"></i>
                </div>
                <span class="text-white text-sm font-medium tracking-wide"><%= success %></span>
            </div>
        </div>
    <% } %>

    <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20 py-12">

        <!-- Page Header -->
        <div class="flex items-center gap-4 mb-12 animate-fade-in-up">
            <a href="/shop" class="w-11 h-11 rounded-2xl bg-white border border-gray-200/80 flex items-center justify-center hover:bg-gray-50 hover:border-gray-300 hover:shadow-sm transition-all duration-300 group">
                <i class="ri-arrow-left-s-line text-lg text-dark-600 group-hover:text-dark-900 transition-colors"></i>
            </a>
            <div>
                <h1 class="text-3xl md:text-4xl font-serif font-bold text-dark-900 tracking-tight">Shopping Cart</h1>
                <p class="text-dark-400 text-sm mt-1 tracking-wide"><%= user.cart.length %> item(s) in your cart</p>
            </div>
        </div>

        <% if(user.cart.length === 0){ %>
            <!-- Empty Cart State -->
            <div class="flex flex-col items-center justify-center py-28 animate-fade-in-up">
                <div class="relative mb-8">
                    <div class="w-28 h-28 rounded-full bg-gradient-to-br from-brand-50 to-brand-100/50 flex items-center justify-center">
                        <i class="ri-shopping-cart-2-line text-5xl text-brand-300"></i>
                    </div>
                    <div class="absolute -top-1 -right-1 w-8 h-8 rounded-full bg-brand-500/10 flex items-center justify-center">
                        <i class="ri-emotion-sad-line text-brand-500 text-sm"></i>
                    </div>
                </div>
                <h2 class="text-3xl font-serif font-semibold text-dark-800 mb-3">Your cart is empty</h2>
                <p class="text-dark-400 text-sm mb-10 text-center max-w-sm leading-relaxed">Looks like you haven't added any bags to your cart yet. Browse our premium collection and find your perfect match!</p>
                <a href="/shop" class="btn-primary text-white font-semibold px-10 py-4 rounded-2xl text-sm tracking-wide inline-flex items-center gap-2.5 group">
                    <i class="ri-shopping-bag-line group-hover:scale-110 transition-transform"></i>
                    Browse Collection
                    <i class="ri-arrow-right-line text-xs opacity-0 -ml-2 group-hover:opacity-100 group-hover:ml-0 transition-all"></i>
                </a>
            </div>
        <% } else { %>

            <div class="flex flex-col lg:flex-row gap-10">

                <!-- Cart Items Column -->
                <div class="flex-1 space-y-5">
                    <% user.cart.forEach(function(item, index){ %>
                        <div class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-lg hover:border-gray-200/80 overflow-hidden transition-all duration-500 animate-fade-in-up" style="animation-delay: <%= index * 0.1 %>s; opacity: 0;">
                            <div class="flex flex-col sm:flex-row">

                                <!-- Product Image -->
                                <div class="sm:w-52 h-52 sm:h-auto flex items-center justify-center flex-shrink-0 p-8 relative overflow-hidden" style="background-color: <%= item.bgcolor %>">
                                    <img class="h-36 object-contain drop-shadow-lg group-hover:scale-105 transition-transform duration-500"
                                         src="data:image/<%= item.image[0] === 0xFF ? 'jpeg' : item.image[0] === 0x89 ? 'png' : item.image.toString('utf8').includes('<svg') ? 'svg+xml' : 'jpeg' %>;base64,<%= item.image.toString('base64') %>"
                                         alt="<%= item.name %>">
                                    <!-- Subtle shine overlay on hover -->
                                    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700"></div>
                                </div>

                                <!-- Product Details -->
                                <div class="flex-1 p-6 sm:p-7 flex flex-col justify-between min-h-[160px]">
                                    <div>
                                        <div class="flex justify-between items-start gap-4">
                                            <div>
                                                <h3 class="text-lg font-semibold text-dark-900 tracking-tight leading-snug"><%= item.name %></h3>
                                                <p class="text-dark-400 text-xs mt-1.5 uppercase tracking-widest font-medium">Premium Collection</p>
                                            </div>
                                            <!-- Remove Button -->
                                            <a href="/remove-from-cart/<%= item._id %>"
                                               class="w-10 h-10 rounded-xl bg-gray-50 border border-gray-100 flex items-center justify-center text-dark-300 hover:bg-red-50 hover:border-red-200 hover:text-red-500 active:scale-95 transition-all duration-300 flex-shrink-0"
                                               title="Remove item">
                                                <i class="ri-delete-bin-6-line text-[15px]"></i>
                                            </a>
                                        </div>
                                    </div>

                                    <div class="flex items-end justify-between mt-5 pt-4 border-t border-gray-50">
                                        <div class="flex items-center gap-3">
                                            <% if(item.discount > 0){ %>
                                                <span class="text-sm text-dark-300 line-through font-medium">₹ <%= item.price %></span>
                                                <span class="px-2.5 py-1 rounded-lg bg-emerald-50 text-emerald-600 text-xs font-bold tracking-wide">−₹<%= item.discount %></span>
                                            <% } %>
                                        </div>
                                        <span class="text-2xl font-bold text-dark-900 tracking-tight">₹ <%= item.price - (item.discount || 0) %></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <!-- Order Summary Sidebar -->
                <div class="lg:w-96 flex-shrink-0">
                    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-7 sticky top-24 animate-fade-in-up stagger-2">

                        <h3 class="text-lg font-bold text-dark-900 mb-1 flex items-center gap-2.5">
                            <div class="w-8 h-8 rounded-lg bg-brand-50 flex items-center justify-center">
                                <i class="ri-receipt-line text-brand-500 text-sm"></i>
                            </div>
                            Order Summary
                        </h3>
                        <p class="text-xs text-dark-300 mb-6 ml-[42px]"><%= user.cart.length %> item(s)</p>

                        <!-- Item Breakdown -->
                        <div class="space-y-3.5 pb-6 border-b border-dashed border-gray-200">
                            <% user.cart.forEach(function(item){ %>
                                <div class="flex justify-between text-sm group/row">
                                    <span class="text-dark-500 truncate mr-4 group-hover/row:text-dark-700 transition-colors"><%= item.name %></span>
                                    <span class="text-dark-700 font-semibold flex-shrink-0 tabular-nums">₹ <%= item.price %></span>
                                </div>
                            <% }) %>
                        </div>

                        <!-- Price Summary -->
                        <div class="space-y-3 py-6 border-b border-gray-100">
                            <div class="flex justify-between text-sm">
                                <span class="text-dark-400">Subtotal</span>
                                <span class="text-dark-700 font-medium tabular-nums">₹ <%= bill - 20 %></span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-dark-400">Platform Fee</span>
                                <span class="text-dark-700 font-medium tabular-nums">₹ 20</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-dark-400">Shipping</span>
                                <span class="text-emerald-600 font-bold text-xs bg-emerald-50 px-2.5 py-0.5 rounded-full">FREE</span>
                            </div>
                        </div>

                        <!-- Total -->
                        <div class="flex justify-between items-center py-6">
                            <span class="text-base font-bold text-dark-900">Total Amount</span>
                            <span class="text-2xl font-bold text-dark-900 tracking-tight tabular-nums">₹ <%= bill %></span>
                        </div>

                        <!-- Place Order CTA -->
                        <a href="/place-order" class="w-full btn-primary text-white font-semibold py-4 rounded-xl text-sm tracking-wide flex items-center justify-center gap-2.5 group block">
                            <i class="ri-shield-check-line text-base group-hover:scale-110 transition-transform"></i>
                            Place Order
                        </a>

                        <!-- Continue Shopping -->
                        <a href="/shop" class="w-full mt-3 py-3.5 rounded-xl border border-gray-200 text-dark-500 text-sm font-medium flex items-center justify-center gap-2 hover:bg-gray-50 hover:border-gray-300 hover:text-dark-700 transition-all duration-300 group">
                            <i class="ri-arrow-left-line text-xs group-hover:-translate-x-0.5 transition-transform"></i>
                            Continue Shopping
                        </a>

                        <!-- Trust Badges -->
                        <div class="mt-6 pt-5 border-t border-gray-100 flex items-center justify-center gap-5 text-dark-300">
                            <div class="flex items-center gap-1.5 text-[11px]">
                                <i class="ri-lock-2-line text-sm"></i>
                                <span>Secure</span>
                            </div>
                            <div class="flex items-center gap-1.5 text-[11px]">
                                <i class="ri-truck-line text-sm"></i>
                                <span>Free Delivery</span>
                            </div>
                            <div class="flex items-center gap-1.5 text-[11px]">
                                <i class="ri-refresh-line text-sm"></i>
                                <span>Easy Returns</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        <% } %>
    </div>

<%- include('./partials/footer') %>