<%- include('./partials/header') %>

    <!-- Flash Success -->
    <% if(typeof success !== 'undefined' && success.length > 0){ %>
        <div class="flash-message fixed top-20 left-1/2 -translate-x-1/2 z-50 px-6 py-3 rounded-xl bg-emerald-500/95 backdrop-blur-sm shadow-lg shadow-emerald-500/20">
            <div class="flex items-center gap-2">
                <i class="ri-check-line text-white text-lg"></i>
                <span class="text-white text-sm font-medium"><%= success %></span>
            </div>
        </div>
    <% } %>

    <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20 py-10">
        <!-- Page Header -->
        <div class="flex items-center gap-3 mb-10 animate-fade-in-up">
            <a href="/shop" class="w-10 h-10 rounded-xl bg-gray-100 flex items-center justify-center hover:bg-gray-200 transition-colors">
                <i class="ri-arrow-left-line text-dark-700"></i>
            </a>
            <div>
                <h1 class="text-2xl md:text-3xl font-serif font-bold text-dark-900">Shopping Cart</h1>
                <p class="text-dark-400 text-sm"><%= user.cart.length %> item(s) in your cart</p>
            </div>
        </div>

        <% if(user.cart.length === 0){ %>
            <!-- Empty Cart -->
            <div class="flex flex-col items-center justify-center py-24 animate-fade-in-up">
                <div class="w-24 h-24 rounded-full bg-gray-100 flex items-center justify-center mb-6">
                    <i class="ri-shopping-cart-line text-4xl text-dark-200"></i>
                </div>
                <h2 class="text-2xl font-serif font-semibold text-dark-700 mb-2">Your cart is empty</h2>
                <p class="text-dark-400 text-sm mb-8 text-center max-w-md">Looks like you haven't added any bags to your cart yet. Browse our premium collection and find your perfect match!</p>
                <a href="/shop" class="btn-primary text-white font-semibold px-8 py-3.5 rounded-xl text-sm tracking-wide inline-flex items-center gap-2">
                    <i class="ri-shopping-bag-line"></i>
                    Browse Collection
                </a>
            </div>
        <% } else { %>

            <div class="flex flex-col lg:flex-row gap-10">

                <!-- Cart Items -->
                <div class="flex-1 space-y-5">
                    <% user.cart.forEach(function(item, index){ %>
                        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden animate-fade-in-up" style="animation-delay: <%= index * 0.1 %>s; opacity: 0;">
                            <div class="flex flex-col sm:flex-row">
                                <!-- Item Image -->
                                <div class="sm:w-48 h-48 sm:h-auto flex items-center justify-center flex-shrink-0 p-6" style="background-color: <%= item.bgcolor %>">
                                    <img class="h-32 object-contain drop-shadow-md"
                                         src="data:image/<%= item.image[0] === 0xFF ? 'jpeg' : item.image[0] === 0x89 ? 'png' : item.image.toString('utf8').includes('<svg') ? 'svg+xml' : 'jpeg' %>;base64,<%= item.image.toString('base64') %>"
                                         alt="<%= item.name %>">
                                </div>

                                <!-- Item Details -->
                                <div class="flex-1 p-6 flex flex-col justify-between">
                                    <div>
                                        <div class="flex justify-between items-start">
                                            <div>
                                                <h3 class="text-lg font-semibold text-dark-900"><%= item.name %></h3>
                                                <p class="text-dark-400 text-sm mt-1">Premium Collection</p>
                                            </div>
                                            <a href="/remove-from-cart/<%= item._id %>" 
                                               class="w-9 h-9 rounded-lg bg-red-50 flex items-center justify-center text-red-500 hover:bg-red-500 hover:text-white transition-all group"
                                               title="Remove item">
                                                <i class="ri-delete-bin-6-line text-base"></i>
                                            </a>
                                        </div>
                                    </div>

                                    <div class="flex items-end justify-between mt-4">
                                        <div class="flex items-center gap-3">
                                            <% if(item.discount > 0){ %>
                                                <span class="text-sm text-dark-400 line-through">₹ <%= item.price %></span>
                                                <span class="px-2.5 py-1 rounded-lg bg-green-50 text-green-600 text-xs font-bold">-₹<%= item.discount %></span>
                                            <% } %>
                                        </div>
                                        <span class="text-xl font-bold text-dark-900">₹ <%= item.price - (item.discount || 0) %></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <!-- Order Summary -->
                <div class="lg:w-96">
                    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-7 sticky top-24 animate-fade-in-up stagger-2">
                        <h3 class="text-lg font-bold text-dark-900 mb-6 flex items-center gap-2">
                            <i class="ri-file-list-3-line text-brand-500"></i>
                            Order Summary
                        </h3>

                        <div class="space-y-4 pb-6 border-b border-gray-100">
                            <% user.cart.forEach(function(item){ %>
                                <div class="flex justify-between text-sm">
                                    <span class="text-dark-500 truncate mr-4"><%= item.name %></span>
                                    <span class="text-dark-700 font-medium flex-shrink-0">₹ <%= item.price %></span>
                                </div>
                            <% }) %>
                        </div>

                        <div class="space-y-3 py-6 border-b border-gray-100">
                            <div class="flex justify-between text-sm">
                                <span class="text-dark-500">Subtotal</span>
                                <span class="text-dark-700 font-medium">₹ <%= bill - 20 %></span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-dark-500">Platform Fee</span>
                                <span class="text-dark-700 font-medium">₹ 20</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-dark-500">Shipping</span>
                                <span class="text-emerald-600 font-semibold">FREE</span>
                            </div>
                        </div>

                        <div class="flex justify-between items-center py-6">
                            <span class="text-base font-bold text-dark-900">Total Amount</span>
                            <span class="text-2xl font-bold text-emerald-600">₹ <%= bill %></span>
                        </div>

                        <a href="/place-order"class="w-full btn-primary text-white font-semibold py-4 rounded-xl text-sm tracking-wide flex items-center justify-center gap-2 block">
                            <i class="ri-lock-line"></i>
                            Place Order
                        </a>

                        <a href="/shop" class="w-full mt-3 py-3 rounded-xl border border-gray-200 text-dark-600 text-sm font-medium flex items-center justify-center gap-2 hover:bg-gray-50 transition-colors">
                            <i class="ri-arrow-left-line"></i>
                            Continue Shopping
                        </a>
                    </div>
                </div>
            </div>

        <% } %>
    </div>

<%- include('./partials/footer') %>